<% const pageTitle = 'Staff Login'; %>
<%- include('partials/header', { title: pageTitle }) %>
<section class="auth-grid">
  <div class="card compact">
    <h1>Staff login</h1>
    <p class="muted">Sign in as Faculty or HOD to manage no-due workflows.</p>
    <% if (error) { %>
    <div class="alert"><%= error %></div>
    <% } %>
    <form method="POST" action="/login" class="stack">
      <label class="field">
        <span>Staff ID</span>
        <input name="staffId" type="text" placeholder="User ID" required />
      </label>
      <label class="field">
        <span>Password</span>
        <input name="password" type="password" placeholder="Enter password" required />
      </label>
      <button type="submit" class="btn btn-primary">Continue</button>
    </form>

    <div style="margin-top:14px;display:flex;flex-direction:column;gap:10px;">
      <a href="/auth/microsoft" class="btn btn-outline-primary btn-ms">
        <span class="ms-icon" aria-hidden="true"></span>
        <span>Login with Microsoft</span>
      </a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
