	wrapTablesForScroll();

	// Helper function to show toast notification
	const showToast = (message, duration = 2000) => {
		const toast = document.createElement('div');
		toast.style.cssText = `
			position: fixed;
			bottom: 20px;
			right: 20px;
			background: #10b981;
			color: white;
			padding: 12px 20px;
			border-radius: 6px;
			font-size: 14px;
			z-index: 9999;
			box-shadow: 0 4px 6px rgba(0,0,0,0.1);
		`;
		toast.textContent = message;
		document.body.appendChild(toast);
		setTimeout(() => toast.remove(), duration);
	};

	// AUTO-SAVE: Submit checkbox changes automatically via AJAX (Bulk assignments)
	const bulkForm = document.querySelector('form[action="/faculty/requests/bulk-assignments"]');
	if (bulkForm) {
		const checkboxes = bulkForm.querySelectorAll('input[type="checkbox"]');
		const textInputs = bulkForm.querySelectorAll('input[type="text"][name*="facultyNote"]');
		
		const autoSubmitForm = async () => {
			// Collect form data manually
			const assignments = {};
			const subjectCodeField = bulkForm.querySelector('input[name="subjectCode"]');
			const subjectCode = subjectCodeField?.value || '';
			
			// Get all checkbox groups
			bulkForm.querySelectorAll('input[type="checkbox"], input[type="text"][name*="facultyNote"]').forEach((input) => {
				const nameAttr = input.getAttribute('name');
				if (!nameAttr) return;
				
				// Parse assignments[id][fieldName] format
				const match = nameAttr.match(/assignments\[([^\]]+)\]\[([^\]]+)\]/);
				if (!match) return;
				
				const [, id, fieldName] = match;
				if (!assignments[id]) {
					assignments[id] = {};
				}
				
				if (input.type === 'checkbox') {
					assignments[id][fieldName] = input.checked;
				} else if (input.type === 'text') {
					assignments[id][fieldName] = input.value;
				}
			});
			
			try {
				const response = await fetch('/faculty/requests/bulk-assignments', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({ assignments, subjectCode }),
				});
				
				if (response.ok) {
					showToast('✓ Saved successfully');
				} else {
					showToast('⚠ Save failed', 2000);
				}
			} catch (err) {
				console.error('Auto-save failed:', err);
				showToast('✗ Network error', 2000);
			}
		};
		
		// Debounce function to avoid too many requests
		let saveTimeout;
		const debouncedSave = () => {
			clearTimeout(saveTimeout);
			saveTimeout = setTimeout(autoSubmitForm, 500);
		};
		
		// Add listeners to all checkboxes
		checkboxes.forEach((checkbox) => {
			checkbox.addEventListener('change', debouncedSave);
		});
		
		// Also auto-save when remarks text changes
		textInputs.forEach((input) => {
			input.addEventListener('change', debouncedSave);
		});
	}

	// AUTO-SAVE: HOD mentee approvals via checkboxes (no page reload)
	const hodMentorToggles = Array.from(document.querySelectorAll('.hod-mentor-status-toggle'));
	if (hodMentorToggles.length) {
		const updateHodMenteeStatus = async (requestId, action) => {
			const response = await fetch(`/hod/requests/${encodeURIComponent(requestId)}/autosave-status`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({ action }),
			});

			if (!response.ok) {
				throw new Error(`Save failed: ${response.status}`);
			}

			return response.json();
		};

		hodMentorToggles.forEach((toggle) => {
			toggle.addEventListener('change', async () => {
				const requestId = toggle.dataset.requestId || '';
				const row = toggle.closest('.hod-mentor-row');
				if (!requestId || !row) return;

				const approveToggle = row.querySelector('.hod-mentor-status-toggle[data-action="approve"]');
				const denyToggle = row.querySelector('.hod-mentor-status-toggle[data-action="deny"]');
				const statusText = row.querySelector('.hod-mentor-status-text');
				if (!approveToggle || !denyToggle || !statusText) return;

				const prevApprove = approveToggle.checked;
				const prevDeny = denyToggle.checked;

				let action = 'pending';
				if (toggle.dataset.action === 'approve') {
					if (toggle.checked) {
						denyToggle.checked = false;
						action = 'approve';
					}
				} else if (toggle.dataset.action === 'deny') {
					if (toggle.checked) {
						approveToggle.checked = false;
						action = 'deny';
					}
				}

				if (!approveToggle.checked && !denyToggle.checked) {
					action = 'pending';
				}

				approveToggle.disabled = true;
				denyToggle.disabled = true;

				try {
					const result = await updateHodMenteeStatus(requestId, action);
					if (result && result.ok && result.status) {
						statusText.textContent = result.status;
						showToast('✓ Mentee status saved');
					} else {
						throw new Error('Invalid response');
					}
				} catch (err) {
					console.error('HOD mentee autosave failed:', err);
					approveToggle.checked = prevApprove;
					denyToggle.checked = prevDeny;
					showToast('✗ Save failed', 2000);
				} finally {
					approveToggle.disabled = false;
					denyToggle.disabled = false;
				}
			});
		});
	}

	// Student approvals detail view
	window.loadStudentApprovals = async function(rollNumber, event) {
		if (event) event.preventDefault();
		
		const listPanel = document.querySelector('[data-panel="student-list-by-department"]');
		const detailPanel = document.querySelector('[data-panel="student-approval-detail"]');
		const loadingDiv = document.getElementById('student-approval-loading');
		const contentDiv = document.getElementById('student-approval-content');
		const errorDiv = document.getElementById('student-approval-error');
		const titleDiv = document.getElementById('student-approval-detail-title');
		
		// Hide list, show detail panel
		if (listPanel) listPanel.style.display = 'none';
		if (detailPanel) detailPanel.style.display = 'block';
		
		loadingDiv.style.display = 'block';
		contentDiv.style.display = 'none';
		errorDiv.style.display = 'none';
		
		try {
			const response = await fetch(`/api/hod/student/${encodeURIComponent(rollNumber)}/pending-approvals`);
			const data = await response.json();
			
			if (!response.ok) {
				throw new Error(data.error || 'Failed to load student approvals');
			}
			
			titleDiv.textContent = `${data.student.name} (${data.student.rollNumber}) - Approvals`;
			// Add HOD final-approve button (enabled only when overallStatus is Approved)
			const canFinalApprove = (data.overallStatus === 'Approved');
			let finalBtnHtml = '';
			if (canFinalApprove) {
				finalBtnHtml = `<button id="hod-final-approve-btn" class="btn btn-accent">Toggle HOD Final Approval</button>`;
			} else {
				finalBtnHtml = `<button id="hod-final-approve-btn" class="btn btn-outline" disabled>Final approval inactive</button>`;
			}
			if (titleDiv) titleDiv.insertAdjacentHTML('afterend', `<div style="margin-top:8px;margin-bottom:8px;">${finalBtnHtml}</div>`);
			let html = '<div class="stack">';
			html += `<div style="background:#f5f5f5;padding:12px;border-radius:4px;margin-bottom:16px;">
				<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
					<div><strong>Roll:</strong> ${data.student.rollNumber}</div>
					<div><strong>Name:</strong> ${data.student.name}</div>
					<div><strong>Department:</strong> ${data.student.department || 'N/A'}</div>
					<div><strong>Year:</strong> ${data.student.year || 'N/A'} | <strong>Section:</strong> ${data.student.section || 'N/A'}</div>
				</div>
			</div>`;
			
			if (!data.pendingApprovals || data.pendingApprovals.length === 0) {
				html += '<p class="muted">No pending approvals for this student.</p>';
			} else {
				html += '<form id="student-approvals-form" class="stack">';
				
				// Build table
				html += `<div style="overflow-x:auto;margin-bottom:16px;">
					<table style="width:100%;border-collapse:collapse;font-size:0.95em;">
						<thead>
							<tr style="background:#2c3e50;color:white;border-bottom:2px solid #1a252f;">
								<th style="padding:10px;text-align:center;width:50px;">
									<input type="checkbox" id="select-all-checkbox" onclick="toggleAllCheckboxes()" />
								</th>
								<th style="padding:10px;text-align:left;">Faculty</th>
								<th style="padding:10px;text-align:left;">Subject</th>
								<th style="padding:10px;text-align:center;">Code</th>
								<th style="padding:10px;text-align:center;">Status</th>
								<th style="padding:10px;text-align:left;">Reason</th>
								<th style="padding:10px;text-align:left;">Faculty Note</th>
							</tr>
						</thead>
						<tbody>`;
				
				let rowCount = 0;
				data.pendingApprovals.forEach(faculty => {
					faculty.requests.forEach(req => {
						rowCount++;
						const bgColor = rowCount % 2 === 0 ? '#ffffff' : '#f9f9f9';
						const statusColor = req.status === 'Approved' ? '#4caf50' : req.status === 'Rejected by Faculty' || req.status === 'Rejected by HOD' ? '#f44336' : '#ff9800';
						
						html += `<tr style="background:${bgColor};border-bottom:1px solid #e0e0e0;">
							<td style="padding:10px;text-align:center;">
								<input type="checkbox" value="${req.id}" name="requestIds" />
							</td>
							<td style="padding:10px;font-weight:500;color:#2196F3;">${faculty.facultyName || 'Unassigned'}</td>
							<td style="padding:10px;">${req.subjectName}</td>
							<td style="padding:10px;text-align:center;font-weight:600;">${req.subjectCode}</td>
							<td style="padding:10px;text-align:center;">
								<span style="background:${statusColor};color:white;padding:4px 8px;border-radius:3px;font-size:0.85em;font-weight:500;">
									${req.status}
								</span>
							</td>
							<td style="padding:10px;font-size:0.9em;color:#666;">${req.reason || '-'}</td>
							<td style="padding:10px;font-size:0.9em;color:#666;">${req.facultyNote || '-'}</td>
						</tr>`;
					});
				});
				
				html += `</tbody>
					</table>
				</div>`;
				
				html += `<div style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap;">
					<button type="button" class="btn btn-accent" onclick="approveSelectedRequests()">
						Force Approve Selected
					</button>
					<button type="button" class="btn btn-outline-primary" onclick="clearSelectedRequests()">
						Clear Selection
					</button>
					<span id="selection-count" class="muted" style="align-self:center;margin-left:auto;"></span>
				</div>
				</form>`;
			}
			
			html += '</div>';
			contentDiv.innerHTML = html;

			// wire final approve button if present
			const finalBtnEl = document.getElementById('hod-final-approve-btn');
			if (finalBtnEl) {
				finalBtnEl.addEventListener('click', async () => {
					try {
					const response = await fetch(`/hod/students/${encodeURIComponent(data.student.rollNumber)}/final-approve`, { method: 'POST' });
					if (response.ok) {
						showToast('✓ HOD Approval updated', 1500);
						// Update default status box if on login page
						const statusBox = document.getElementById('default-hod-status');
						if (statusBox) {
							statusBox.style.background = '#d1fae5';
							statusBox.style.borderColor = '#10b981';
							const statusText = statusBox.querySelector('#hod-status-text');
							if (statusText) {
								statusText.style.color = '#065f46';
								statusText.textContent = '✓ HOD APPROVED';
							}
							let dateDiv = statusBox.querySelector('#hod-approval-date');
							if (!dateDiv) {
								dateDiv = document.createElement('div');
								dateDiv.id = 'hod-approval-date';
								dateDiv.style.cssText = 'font-size:0.9em;color:#047857;margin-top:4px;';
								statusBox.querySelector('div > div').appendChild(dateDiv);
							}
							dateDiv.textContent = 'Approved on ' + new Date().toLocaleDateString();
						}
					}
				} catch (err) {
					console.error('Failed to toggle final approval', err);
					showToast('✗ Failed to update approval', 2000);
				}
			});
			}
			
			// Add event listeners for checkboxes
			setTimeout(() => {
				const selectAllCheckbox = document.getElementById('select-all-checkbox');
				if (selectAllCheckbox) {
					selectAllCheckbox.addEventListener('change', function() {
						const checkboxes = document.querySelectorAll('input[name="requestIds"]');
						checkboxes.forEach(cb => cb.checked = this.checked);
						updateSelectionCount();
					});
				}
				
				// Add event listeners to individual checkboxes
				const checkboxes = document.querySelectorAll('input[name="requestIds"]');
				checkboxes.forEach(cb => {
					cb.addEventListener('change', updateSelectionCount);
				});
			}, 0);
		} catch (err) {
			console.error('Error loading student approvals:', err);
			errorDiv.textContent = 'Error: ' + (err.message || 'Failed to load approvals');
			loadingDiv.style.display = 'none';
			errorDiv.style.display = 'block';
		}
	};

	window.toggleAllCheckboxes = function() {
		const selectAllCheckbox = document.getElementById('select-all-checkbox');
		const checkboxes = document.querySelectorAll('input[name="requestIds"]');
		checkboxes.forEach(cb => cb.checked = selectAllCheckbox.checked);
		updateSelectionCount();
	};

	window.updateSelectionCount = function() {
		const checkboxes = document.querySelectorAll('input[name="requestIds"]:checked');
		const countSpan = document.getElementById('selection-count');
		if (countSpan) {
			countSpan.textContent = checkboxes.length > 0 ? `${checkboxes.length} selected` : '';
		}
	};

	window.backToStudentList = function() {
		const listPanel = document.querySelector('[data-panel="student-list-by-department"]');
		const detailPanel = document.querySelector('[data-panel="student-approval-detail"]');
		if (listPanel) listPanel.style.display = 'block';
		if (detailPanel) detailPanel.style.display = 'none';
	};

	window.approveSelectedRequests = async function() {
		const form = document.getElementById('student-approvals-form');
		const checkboxes = form.querySelectorAll('input[name="requestIds"]:checked');
		if (checkboxes.length === 0) {
			showToast('✗ No requests selected', 2000);
			return;
		}

		const requestIds = Array.from(checkboxes).map(cb => cb.value);
		
		try {
			const response = await fetch('/hod/requests/force-approve', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ requestIds, redirectPanel: 'student-list-by-department' })
			});
			
			const data = await response.json();
			if (!response.ok) throw new Error(data.error || 'Failed to approve');
			
			showToast('✓ ' + data.message, 1500);
			
			// Disable checked checkboxes immediately
			checkboxes.forEach(cb => {
				cb.checked = false;
				cb.disabled = true;
			});
			updateSelectionCount();
			
			// Go back to student list and reload
			setTimeout(() => {
				backToStudentList();
				location.reload();
			}, 800);
		} catch (err) {
			console.error('Error approving requests:', err);
			showToast('✗ ' + err.message, 2000);
		}
	};

	window.clearSelectedRequests = function() {
		const form = document.getElementById('student-approvals-form');
		const checkboxes = form.querySelectorAll('input[name="requestIds"]');
		const selectAllCheckbox = document.getElementById('select-all-checkbox');
		checkboxes.forEach(cb => cb.checked = false);
		if (selectAllCheckbox) selectAllCheckbox.checked = false;
		updateSelectionCount();
	};

	window.toggleHodApproval = async function(rollNumber, event) {
		event.stopPropagation();
		
		try {
			const response = await fetch(`/hod/students/${encodeURIComponent(rollNumber)}/final-approve`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({})
			});
			
			const data = await response.json();
			if (!response.ok) throw new Error(data.error || 'Failed to toggle HOD approval');
			
			// Find the button that was clicked
			const btn = event.target.closest('button');
			if (btn) {
				// Update button immediately to green
				btn.style.background = '#10b981';
				btn.style.color = 'white';
				btn.textContent = '✓ HOD Approved';
				btn.disabled = true;
			}
			
			// Update the default HOD status box on the page (for login page)
			const statusBox = document.getElementById('default-hod-status');
			if (statusBox) {
				statusBox.style.background = '#d1fae5';
				statusBox.style.borderColor = '#10b981';
				const statusText = statusBox.querySelector('#hod-status-text');
				if (statusText) {
					statusText.style.color = '#065f46';
					statusText.textContent = '✓ HOD APPROVED';
				}
				let dateDiv = statusBox.querySelector('#hod-approval-date');
				if (!dateDiv) {
					dateDiv = document.createElement('div');
					dateDiv.id = 'hod-approval-date';
					dateDiv.style.cssText = 'font-size:0.9em;color:#047857;margin-top:4px;';
					statusBox.querySelector('div > div').appendChild(dateDiv);
				}
				dateDiv.textContent = 'Approved on ' + new Date().toLocaleDateString();
			}
			
			showToast('✓ HOD Approval updated successfully', 1500);
		} catch (err) {
			console.error('Error toggling HOD approval:', err);
			showToast('✗ ' + (err.message || 'Failed to update'), 2000);
		}
	};
})();
</script>

