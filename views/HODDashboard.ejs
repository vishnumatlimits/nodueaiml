<% const pageTitle = 'HOD Dashboard'; %>
<%- include('partials/header', { title: pageTitle }) %>

<div class="layout-wrap">
	<aside class="sidebar">
		<h2>HOD</h2>
		<a href="#hod-analytics" data-target="hod-analytics" class="active">Analytics</a>
		<a href="#hod-subject-data" data-target="hod-subject-data">Approvals</a>
		<a href="#hod-mentee-data" data-target="hod-mentee-data">Mentee approvals</a>
		<a href="#student-list-by-department" data-target="student-list-by-department">Student approvals</a>
		<a href="#hod-force-approved" data-target="hod-force-approved">Force-approved students</a>
		<a href="#manage-students" data-target="manage-students">Manage students</a>
		<a href="#manage-faculty" data-target="manage-faculty">Manage faculty</a>
		<a href="#manage-subjects" data-target="manage-subjects">Manage subjects</a>
		<a href="#manage-mentors" data-target="manage-mentors">Manage mentors</a>
		<a href="#manage-objective-approvals" data-target="manage-objective-approvals">Objective approvals</a>
		<a href="#profile" data-target="profile">Profile</a>
		<form action="/logout" method="POST">
			<button type="submit" class="link-btn logout">Logout</button>
		</form>
	</aside>

	<section class="content stack">
		<div class="panel" data-panel="profile">
			<div class="card" id="profile">
				<div class="flex-between">
					<h2>Profile</h2>
					<span class="badge">Update your info</span>
				</div>
				<% if (profileError) { %>
					<div class="alert"><%= profileError %></div>
				<% } %>
				<% if (profileSuccess) { %>
					<div class="alert success"><%= profileSuccess %></div>
				<% } %>

				<form action="/hod/profile" method="POST" class="stack">
					<label class="field">
						<span>Name</span>
						<input type="text" name="name" value="<%= self?.name || '' %>" placeholder="Enter name" />
					</label>
					<label class="field">
						<span>Faculty ID</span>
						<input type="text" name="facultyId" value="<%= self?.facultyId || '' %>" placeholder="Enter faculty ID" />
					</label>
					<label class="field">
						<span>New password</span>
						<input type="password" name="password" placeholder="Leave blank to keep current" />
					</label>
					<p class="muted">Change any field and submit. Password updates are stored securely.</p>
					<button type="submit" class="btn btn-accent">Save changes</button>
				</form>
			</div>
		</div>

		<div class="panel" data-panel="hod-subject-data">
			<div class="card">
				<div class="flex-between">
					<h2 id="hod-subject-data">Subject wise Faculty Approval Information</h2>
					<span class="badge"><%= hodSubjectGroups && hodSubjectGroups.length ? hodSubjectGroups.length + ' subjects' : 'No subjects' %></span>
				</div>

				<div class="grid two" style="margin-top:12px;">
					<label class="field">
						<span>Search in subject approvals</span>
						<input type="text" id="hod-subject-search" placeholder="Search by name, roll number, year, section, department" />
					</label>
				</div>

				<% if (!hodSubjectGroups || !hodSubjectGroups.length) { %>
					<p class="muted">No assigned subjects available yet.</p>
				<% } else { %>
					<div style="display:flex;flex-direction:column;gap:12px;margin-top:14px;">
						<% hodSubjectGroups.forEach(function(group){ %>
							<details class="card subject-group-card" data-subject="<%= group.subjectCode || 'GENERAL' %>">
								<summary style="cursor:pointer;list-style:none;display:flex;justify-content:space-between;gap:12px;align-items:center;">
									<span>
										<strong>Subject Code: <%= group.subjectCode || 'GENERAL' %></strong>
										<span class="muted"> — <%= group.subjectName || 'N/A' %></span>
									</span>
									<span class="badge"><%= group.pendingCount %> pending / <%= group.totalCount %> total</span>
								</summary>
								<div style="margin-top:12px;">
									<% if (!group.rows.length) { %>
										<p class="muted">No requests available for this subject.</p>
									<% } else { %>
										<div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;margin-bottom:10px;">
											<form action="/faculty/requests/approve-all" method="POST">
												<input type="hidden" name="scope" value="subject" />
												<input type="hidden" name="subjectCode" value="<%= group.subjectCode || '' %>" />
												<input type="hidden" name="bulkAction" value="approve" />
												<input type="hidden" name="redirectPanel" value="hod-subject-data" />
												<button type="submit" class="btn btn-accent btn-sm">Approve all</button>
											</form>
											<form action="/faculty/requests/approve-all" method="POST">
												<input type="hidden" name="scope" value="subject" />
												<input type="hidden" name="subjectCode" value="<%= group.subjectCode || '' %>" />
												<input type="hidden" name="bulkAction" value="revoke" />
												<input type="hidden" name="redirectPanel" value="hod-subject-data" />
												<button type="submit" class="btn btn-outline-primary btn-sm">Revoke all</button>
											</form>
										</div>
										<form action="/faculty/requests/bulk-assignments" method="POST">
											<input type="hidden" name="subjectCode" value="<%= group.subjectCode || '' %>" />
											<table>
												<tr>
													<th>S.No</th>
													<th>Roll Number</th>
													<th>Student Name</th>
													<th>Year</th>
													<th>Section</th>
													<th>Department</th>
													<th>Assignment 1</th>
													<th>Assignment 2</th>
													<th>Status</th>
													<th>Remarks</th>
												</tr>
												<% group.rows.forEach(function(r, idx){ %>
													<tr class="hod-subject-row" data-year="<%= r.year || '' %>" data-section="<%= r.section || '' %>" data-department="<%= r.department || '' %>">
														<td><%= idx + 1 %></td>
														<td><%= r.rollNumber || '-' %></td>
														<td><%= r.studentName || '-' %></td>
														<td><%= r.year || '-' %></td>
														<td><%= r.section || '-' %></td>
														<td><%= r.department || '-' %></td>
														<td style="text-align:center;">
															<input type="checkbox" name="assignments[<%= r.id %>][assignment1]" <%= r.assignment1 ? 'checked' : '' %> />
														</td>
														<td style="text-align:center;">
															<input type="checkbox" name="assignments[<%= r.id %>][assignment2]" <%= r.assignment2 ? 'checked' : '' %> />
														</td>
														<td><%= r.status || '-' %></td>
														<td>
															<input
																type="text"
																name="assignments[<%= r.id %>][facultyNote]"
																value="<%= r.facultyNote || '' %>"
																placeholder="Remarks"
																style="width:100%;max-width:260px;"
															/>
														</td>
													</tr>
												<% }); %>
											</table>
											<div style="margin-top:12px;display:flex;justify-content:flex-end;">
												<button type="submit" class="btn btn-accent btn-sm">Save <%= group.subjectCode || group.subjectName %></button>
											</div>
										</form>
									<% } %>
								</div>
							</details>
						<% }); %>
					</div>
				<% } %>
			</div>
		</div>

		<div class="panel" data-panel="hod-analytics">
			<div class="card">
				<div class="flex-between">
					<h2 id="hod-analytics">Approval analytics</h2>
					<span class="badge"><%= (hodAnalytics && hodAnalytics.overall ? hodAnalytics.overall.pendingHod : 0) %> pending with HOD</span>
				</div>

				<% const analytics = hodAnalytics || { overall: { total: 0, students: 0, approved: 0, pending: 0, denied: 0, pendingHod: 0, pendingFaculty: 0, approvalRate: 0 }, categories: [] }; %>

				<div class="grid two" style="gap:12px;margin-top:12px;">
					<div class="card" style="margin:0;padding:14px;">
						<p class="muted" style="margin:0 0 4px;">Total approval records</p>
						<h3 style="margin:0;"><%= analytics.overall.total %></h3>
					</div>
					<div class="card" style="margin:0;padding:14px;">
						<p class="muted" style="margin:0 0 4px;">Total students (category-wise sum)</p>
						<h3 style="margin:0;"><%= analytics.overall.students %></h3>
					</div>
					<div class="card" style="margin:0;padding:14px;">
						<p class="muted" style="margin:0 0 4px;">Pending HOD</p>
						<h3 style="margin:0;color:#b45309;"><%= analytics.overall.pendingHod %></h3>
					</div>
					<div class="card" style="margin:0;padding:14px;">
						<p class="muted" style="margin:0 0 4px;">Approved</p>
						<h3 style="margin:0;color:#0f766e;"><%= analytics.overall.approved %></h3>
					</div>
				</div>

				<div class="grid two" style="gap:14px;margin-top:14px;">
					<div class="card" style="margin:0;padding:14px;">
						<h3 style="margin:0 0 10px;">Overall status split (<%= analytics.overall.approvalRate %>%)</h3>
						<canvas id="hod-overall-pie" width="220" height="220" style="max-width:220px;"></canvas>
						<div class="muted" id="hod-overall-legend" style="margin-top:10px;"></div>
					</div>
					<div class="card" style="margin:0;padding:14px;">
						<h3 style="margin:0 0 10px;">Category workload split</h3>
						<canvas id="hod-category-pie" width="220" height="220" style="max-width:220px;"></canvas>
						<div class="muted" id="hod-category-legend" style="margin-top:10px;"></div>
					</div>
				</div>

				<div style="margin-top:14px;">
					<table>
						<tr>
							<th>Category</th>
							<th>Total</th>
							<th>Students</th>
							<th>Approved</th>
							<th>Pending</th>
							<th>Denied</th>
							<th>Pending Faculty</th>
							<th>Pending HOD</th>
							<th>Approval %</th>
						</tr>
						<% analytics.categories.forEach(function(c){ %>
							<tr>
								<td><%= c.label %></td>
								<td><%= c.total %></td>
								<td><%= c.students %></td>
								<td><%= c.approved %></td>
								<td><%= c.pending %></td>
								<td><%= c.denied %></td>
								<td><%= c.pendingFaculty %></td>
								<td><%= c.pendingHod %></td>
								<td><%= c.approvalRate %>%</td>
							</tr>
						<% }); %>
					</table>
				</div>

				<script id="hod-analytics-data" type="application/json"><%- JSON.stringify(analytics) %></script>
			</div>
		</div>

		<div class="panel" data-panel="hod-mentee-data">
			<div class="card">
				<div class="flex-between">
					<h2 id="hod-mentee-data">HOD mentee requests</h2>
					<span class="badge">
						<% const pendingCount = (hodMentorRequests || []).filter(r => ['Pending Faculty', 'Pending HOD'].includes(r.status)).length; %>
						<%= pendingCount ? pendingCount + ' pending' : 'No pending mentee requests' %>
					</span>
				</div>

				<div class="grid two" style="margin-top:12px;">
					<label class="field">
						<span>Search in mentee approvals</span>
						<input type="text" id="hod-mentor-search" placeholder="Search by name, roll number, year, section, department" />
					</label>
				</div>

				<div style="display:flex; gap:10px; flex-wrap:wrap; margin:12px 0 16px;">
					<form action="/hod/requests/generate-mentor-subjects" method="POST">
						<button type="submit" class="btn btn-outline-primary">Create mentor requests</button>
					</form>
					<form action="/hod/requests/approve-all-mentee" method="POST" onsubmit="return confirm('Approve all pending mentee requests?');">
						<input type="hidden" name="redirectPanel" value="hod-mentee-data" />
						<button type="submit" class="btn btn-accent">Approve all mentee requests</button>
					</form>
					<form action="/hod/requests/delete-mentor-subjects" method="POST" onsubmit="return confirm('Delete ALL mentor requests? This cannot be undone.');">
						<button type="submit" class="btn btn-danger">Delete mentor requests</button>
					</form>
				</div>

				<% if (!hodMentorRequests || !hodMentorRequests.length) { %>
					<p class="muted">No mentor-related requests pending for HOD review.</p>
				<% } else { %>
					<div style="display:flex;flex-wrap:wrap;gap:8px;margin:10px 0 14px;">
						<button type="button" class="btn btn-outline-primary hod-mentor-subject-chip active" data-mentor-subject="__all">All subjects</button>
						<% hodMentorRequestGroups.forEach(function(subjectGroup){ const subjectFilter = subjectGroup.subjectCode || subjectGroup.subjectName; %>
							<button type="button" class="btn btn-outline-primary hod-mentor-subject-chip" data-mentor-subject="<%= subjectFilter %>">
								<%= subjectGroup.subjectName || subjectGroup.subjectCode || 'Mentor Subject' %>
							</button>
						<% }); %>
					</div>

					<div class="stack" style="gap:14px;">
						<% hodMentorRequestGroups.forEach(function(subjectGroup){ const subjectFilter = subjectGroup.subjectCode || subjectGroup.subjectName; %>
							<details class="card hod-mentor-subject-card" data-mentor-subject="<%= subjectFilter %>" style="margin:0;">
								<summary class="flex-between" style="gap:10px;align-items:flex-start;cursor:pointer;list-style:none;">
									<h3 style="margin:0;"><%= subjectGroup.subjectName || subjectGroup.subjectCode || '-' %></h3>
									<span class="badge"><%= subjectGroup.years.length %> year group(s)</span>
								</summary>

								<div class="stack" style="margin-top:12px;gap:12px;">
									<% subjectGroup.years.forEach(function(group){ %>
										<details class="card hod-mentor-year-card" style="margin:0;padding:0;border:1px solid #e5e7eb;border-radius:6px;">
											<summary style="cursor:pointer;padding:14px;font-weight:600;list-style:none;user-select:none;">Year: <%= group.year %></summary>
											<div style="padding:0 14px 14px;">
												<div class="stack" style="gap:10px;">
													<% group.sections.forEach(function(sectionGroup){ %>
														<details class="card hod-mentor-section-card" style="margin:0;padding:0;border:1px solid #e5e7eb;border-radius:6px;">
															<summary style="cursor:pointer;padding:12px;font-weight:600;list-style:none;user-select:none;color:#666;">Section: <%= sectionGroup.section %></summary>
															<div style="padding:0 12px 12px;">
																<% sectionGroup.departments.forEach(function(deptGroup){ %>
																	<div class="muted" style="margin:6px 0;font-weight:600;">Department: <%= deptGroup.department %></div>
																	<table style="margin-top:6px;">
																		<tr>
																			<th>Student</th>
																			<th>Roll number</th>
																			<th>Branch / Year</th>
																			<th>Status</th>
																			<th>Action</th>
																		</tr>
																		<% deptGroup.rows.forEach(function(r){ %>
																		<tr class="hod-mentor-row" data-request-id="<%= r.id %>" data-year="<%= r.year || '' %>" data-section="<%= r.section || '' %>" data-department="<%= r.department || '' %>" data-mentor-subject="<%= subjectFilter %>">
																			<td><%= r.studentName || '-' %></td>
																			<td><%= r.rollNumber || '-' %></td>
																			<td>
																				<%= r.branch || '-' %>
																				<% if (r.year) { %> • Year <%= r.year %><% } %>
																				<% if (r.semester) { %> • Sem <%= r.semester %><% } %>
																			</td>
																			<td><span class="hod-mentor-status-text"><%= r.status || '-' %></span></td>
																			<td>
																				<div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
																					<label style="display:inline-flex;gap:6px;align-items:center;cursor:pointer;">
																						<input type="checkbox" class="hod-mentor-status-toggle" data-request-id="<%= r.id %>" data-action="approve" <%= r.status === 'Approved' ? 'checked' : '' %> />
																						<span>Approve</span>
																					</label>
																					<label style="display:inline-flex;gap:6px;align-items:center;cursor:pointer;">
																						<input type="checkbox" class="hod-mentor-status-toggle" data-request-id="<%= r.id %>" data-action="deny" <%= r.status === 'Rejected by HOD' ? 'checked' : '' %> />
																						<span>Deny</span>
																					</label>
																				</div>
																			</td>
																		</tr>
																		<% }); %>
																	</table>
																<% }); %>
															</div>
														</details>
													<% }); %>
												</div>
											</div>
										</details>
									<% }); %>
								</div>
							</details>
						<% }); %>
					</div>
				<% } %>
			</div>
		</div>

		<div class="panel" data-panel="student-list-by-department">
			<div class="card">
				<div class="flex-between">
					<h2 id="student-list-by-department">Student Approvals by Department</h2>
					<span class="badge">Department / Year / Section</span>
				</div>
				<% if (!studentsByDepartmentYearSection || !studentsByDepartmentYearSection.length) { %>
					<p class="muted" style="margin-top:12px;">No students available.</p>
				<% } else { %>
					<div style="display:flex;flex-direction:column;gap:12px;margin-top:14px;">
						<% studentsByDepartmentYearSection.forEach(function(dept){ %>
							<details class="card" style="border-left:4px solid #e0e0e0;">
								<summary style="cursor:pointer;list-style:none;display:flex;justify-content:space-between;gap:12px;align-items:center;padding:8px;font-weight:600;">
									<span><%= dept.department %></span>
									<span class="badge"><%= dept.years.reduce((sum, y) => sum + y.sections.reduce((s, sec) => s + sec.students.length, 0), 0) %> students</span>
								</summary>
								<div style="margin-top:8px;margin-left:12px;">
									<% dept.years.forEach(function(year){ %>
										<details class="card" style="border-left:3px solid #d0d0d0;">
											<summary style="cursor:pointer;list-style:none;display:flex;justify-content:space-between;gap:12px;align-items:center;padding:6px;font-weight:500;">
												<span>Year <%= year.year %></span>
												<span class="badge"><%= year.sections.reduce((sum, sec) => sum + sec.students.length, 0) %> students</span>
											</summary>
											<div style="margin-top:6px;margin-left:12px;">
												<% year.sections.forEach(function(section){ %>
													<details class="card" style="border-left:2px solid #c0c0c0;">
														<summary style="cursor:pointer;list-style:none;display:flex;justify-content:space-between;gap:12px;align-items:center;padding:4px;font-weight:500;">
															<span>Section <%= section.section %></span>
															<span class="badge"><%= section.students.length %> students</span>
														</summary>
														<div style="margin-top:6px;margin-left:12px;display:flex;flex-direction:column;gap:4px;">
															<% section.students.forEach(function(student){ %>
																<div style="display:flex;justify-content:space-between;align-items:center;padding:6px;background:#f9f9f9;border-radius:4px;" class="student-row">
																	<div style="flex:1;cursor:pointer;" onclick="loadStudentApprovals('<%= student.rollNumber %>', event)">
																		<strong><%= student.rollNumber %></strong>
																		<span class="muted"> - <%= student.name %></span>
																	</div>
																	<div style="display:flex;gap:6px;align-items:center;">
																		<span class="badge" style="<%= student.approvalStatus === 'Approved' ? 'background:#4caf50;color:white;' : 'background:#ff9800;color:white;' %>">
																			<%= student.approvalStatus %>
																		</span>
																		<% if (student.approvalStatus === 'Approved') { %>
																			<button class="btn btn-sm" style="<%= student.hodApproval && student.hodApproval.approved ? 'background:#10b981;color:white;' : 'background:#d1d5db;color:#374151;' %>" onclick="toggleHodApproval('<%= student.rollNumber %>', event)" title="<%= student.hodApproval && student.hodApproval.approved ? 'HOD Approved on ' + new Date(student.hodApproval.approvedAt || student.hodApproval.updatedAt).toLocaleDateString() : 'Click to approve' %>">
																				<%= student.hodApproval && student.hodApproval.approved ? '✓ HOD Approved' : 'HOD Approve' %>
																			</button>
																		<% } %>
																	</div>
																</div>
															<% }); %>
														</div>
													</details>
												<% }); %>
											</div>
										</details>
									<% }); %>
								</div>
							</details>
						<% }); %>
					</div>
				<% } %>
			</div>
		</div>

		<div class="panel" data-panel="student-approval-detail" style="display:none;">
			<div class="card">
				<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
					<h2 id="student-approval-detail-title">Student Approvals</h2>
					<button onclick="backToStudentList()" class="btn btn-outline-primary btn-sm">Back</button>
				</div>
				<div id="student-approval-loading" style="text-align:center;color:#666;">Loading...</div>
				<div id="student-approval-content" style="display:none;"></div>
				<div id="student-approval-error" style="display:none;color:#d32f2f;"></div>
			</div>
		</div>

		<div class="panel" data-panel="hod-force-approved">
			<div class="card">
				<div class="flex-between">
					<h2 id="hod-force-approved">Force-approved by HOD</h2>
					<span class="badge">Recent force approvals</span>
				</div>
				<div id="hod-force-approved-body" style="margin-top:12px;">
					<div class="muted">Loading...</div>
				</div>
			</div>
		</div>

		<div class="panel" data-panel="manage-faculty">
			<div class="card" id="manage-faculty">
			<div class="flex-between">
				<h2>Manage faculty</h2>
				<span class="badge">Add / edit</span>
			</div>
			<form action="/hod/faculty" method="POST" class="stack">
				<div class="grid two">
					<label class="field">
						<span>Name</span>
						<input type="text" name="name" placeholder="Enter Name" required />
					</label>
					<label class="field">
						<span>Faculty ID</span>
						<input type="text" name="facultyId" placeholder="Enter Faculty ID" required />
					</label>
				</div>
				<div class="grid two">
					<label class="field">
						<span>Password</span>
						<input type="password" name="password" placeholder="Enter password" required />
					</label>
					<label class="field">
						<span>Department</span>
						<select name="department" required>
							<option value="">Select department</option>
							<option value="CSM">CSM</option>
							<option value="CSD">CSD</option>
							<option value="CSE">CSC</option>
							<option value="CAI">CAI</option>
							<option value="CSE">CSE</option>
