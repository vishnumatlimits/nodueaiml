<script>
(() => {
	const links = Array.from(document.querySelectorAll('[data-target]'));
	const panels = Array.from(document.querySelectorAll('[data-panel]'));
	const hodSubjectSearchInput = document.getElementById('hod-subject-search');
	const hodMentorSearchInput = document.getElementById('hod-mentor-search');
	const hodObjectiveSearchInput = document.getElementById('hod-objective-search');
	const hodAnalyticsDataNode = document.getElementById('hod-analytics-data');
	const hodTaskStatusDataNode = document.getElementById('hod-task-status-data');
	const hodTaskStatusBody = document.getElementById('hod-task-status-body');
	const hodTaskStatusUpdated = document.getElementById('hod-task-status-updated');
	let hodAnalyticsData = null;
	let hodTaskStatusData = [];

	if (hodAnalyticsDataNode && hodAnalyticsDataNode.textContent) {
		try {
			hodAnalyticsData = JSON.parse(hodAnalyticsDataNode.textContent);
		} catch (err) {
			hodAnalyticsData = null;
		}
	}

	if (hodTaskStatusDataNode && hodTaskStatusDataNode.textContent) {
		try {
			hodTaskStatusData = JSON.parse(hodTaskStatusDataNode.textContent);
		} catch (err) {
			hodTaskStatusData = [];
		}
	}
	const hodMentorSubjectChips = Array.from(document.querySelectorAll('.hod-mentor-subject-chip'));
	const hodMentorSubjectCards = Array.from(document.querySelectorAll('.hod-mentor-subject-card'));
	let currentHodMentorSubject = '__all';
	const escapeHtml = (value) => String(value == null ? '' : value)
		.replace(/&/g, '&amp;')
		.replace(/</g, '&lt;')
		.replace(/>/g, '&gt;')
		.replace(/"/g, '&quot;')
		.replace(/'/g, '&#39;');

	const wrapTablesForScroll = () => {
		document.querySelectorAll('.content table').forEach((table) => {
			if (table.closest('.table-responsive')) return;
			const wrapper = document.createElement('div');
			wrapper.className = 'table-responsive';
			table.parentNode.insertBefore(wrapper, table);
			wrapper.appendChild(table);
		});
	};

	const formatTaskDate = (value) => {
		if (!value) return '-';
		const dt = new Date(value);
		if (Number.isNaN(dt.getTime())) return '-';
		return dt.toLocaleString();
	};

	const renderTaskStateBadge = (task) => {
		if (!task) return '<span class="badge">Unknown</span>';
		if (task.running) {
			return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid #93c5fd;background:#dbeafe;color:#1e3a8a;font-weight:600;font-size:12px;">Running</span>';
		}
		if (task.lastError) {
			return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid #fca5a5;background:#fee2e2;color:#991b1b;font-weight:600;font-size:12px;">Failed</span>';
		}
		return '<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid #86efac;background:#dcfce7;color:#166534;font-weight:600;font-size:12px;">Completed</span>';
	};

	const renderTaskStatusPanel = (tasks) => {
		if (!hodTaskStatusBody) return;
		const safeTasks = Array.isArray(tasks) ? tasks : [];
		hodTaskStatusBody.innerHTML = safeTasks.map((task) => {
			const processed = Number.isFinite(task.processedItems) ? task.processedItems : 0;
			const total = Number.isFinite(task.totalItems) ? task.totalItems : 0;
			const progressText = total > 0 ? `${processed} / ${total}` : `${processed}`;
			return `
				<tr>
					<td>${escapeHtml(task.label || task.key || '-')}</td>
					<td>${renderTaskStateBadge(task)}</td>
					<td><strong>${escapeHtml(progressText)}</strong></td>
					<td>${escapeHtml(formatTaskDate(task.lastCompletedAt))}</td>
					<td>${escapeHtml(task.lastError || '-')}</td>
				</tr>
			`;
		}).join('');

		if (hodTaskStatusUpdated) {
			hodTaskStatusUpdated.textContent = `Updated: ${new Date().toLocaleTimeString()}`;
		}
	};

	const pollTaskStatus = async () => {
		if (!hodTaskStatusBody) return;
		try {
			const response = await fetch('/hod/background-tasks/status', {
				method: 'GET',
				headers: { 'Accept': 'application/json' },
			});
			if (!response.ok) return;
			const payload = await response.json();
			renderTaskStatusPanel(payload.tasks || []);
		} catch (err) {
			// Ignore polling failures to keep dashboard usable.
		}
	};

	const renderPieChart = (canvasId, legendId, segments) => {
		const canvas = document.getElementById(canvasId);
		if (!canvas || !Array.isArray(segments) || !segments.length) return;

		const total = segments.reduce((sum, segment) => sum + (segment.value || 0), 0);
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const width = canvas.width;
		const height = canvas.height;
		const centerX = width / 2;
		const centerY = height / 2;
		const radius = Math.min(centerX, centerY) - 10;

		ctx.clearRect(0, 0, width, height);

		if (!total) {
			ctx.beginPath();
			ctx.arc(centerX, centerY, radius, 0, Math.PI * 2);
			ctx.fillStyle = '#e5e7eb';
			ctx.fill();
			ctx.closePath();
			const legend = document.getElementById(legendId);
			if (legend) legend.textContent = 'No data available yet.';
			return;
		}

		let startAngle = -Math.PI / 2;
		segments.forEach((segment) => {
			const value = segment.value || 0;
			if (!value) return;
			const sliceAngle = (value / total) * Math.PI * 2;

			ctx.beginPath();
			ctx.moveTo(centerX, centerY);
			ctx.arc(centerX, centerY, radius, startAngle, startAngle + sliceAngle);
			ctx.closePath();
			ctx.fillStyle = segment.color;
			ctx.fill();

			startAngle += sliceAngle;
		});

		ctx.beginPath();
		ctx.arc(centerX, centerY, radius * 0.52, 0, Math.PI * 2);
		ctx.fillStyle = '#ffffff';
		ctx.fill();
		ctx.closePath();

		const legend = document.getElementById(legendId);
		if (legend) {
			legend.innerHTML = segments
				.filter((segment) => (segment.value || 0) > 0)
				.map((segment) => {
					const pct = Math.round(((segment.value || 0) / total) * 100);
					return `<span style="display:inline-flex;align-items:center;gap:6px;margin-right:12px;"><span style="display:inline-block;width:10px;height:10px;border-radius:999px;background:${segment.color};"></span>${segment.label}: ${segment.value} (${pct}%)</span>`;
