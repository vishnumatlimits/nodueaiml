// Fetch and render HOD force-approved requests
const loadHodForceApproved = async () => {
	const container = document.getElementById('hod-force-approved-body');
	if (!container) return;
	container.innerHTML = '<div class="muted">Loading...</div>';
	try {
		const res = await fetch('/api/hod/force-approved');
		const data = await res.json();
		if (!res.ok) throw new Error(data.error || 'Load failed');

		let groups = Array.isArray(data.groups) ? data.groups : [];
		if (!groups.length && Array.isArray(data.items) && data.items.length) {
			const deptMap = new Map();
			data.items.forEach((it) => {
				const department = it.department || 'Unassigned';
				const year = it.year || 'No Year';
				const section = it.section || 'No Section';
				const studentKey = `${it.rollNumber || ''}::${(it.studentName || '-').toLowerCase()}`;

				if (!deptMap.has(department)) deptMap.set(department, new Map());
				const yearMap = deptMap.get(department);
				if (!yearMap.has(year)) yearMap.set(year, new Map());
				const sectionMap = yearMap.get(year);
				if (!sectionMap.has(section)) sectionMap.set(section, new Map());
				const studentMap = sectionMap.get(section);

				if (!studentMap.has(studentKey)) {
					studentMap.set(studentKey, {
						rollNumber: it.rollNumber || '',
						studentName: it.studentName || '-',
						subjects: [],
					});
				}

				studentMap.get(studentKey).subjects.push({
					subjectName: it.subjectName || 'General',
					subjectCode: it.subjectCode || 'General',
				});
			});

			groups = Array.from(deptMap.entries()).map(([department, yearMap]) => ({
				department,
				years: Array.from(yearMap.entries()).map(([year, sectionMap]) => ({
					year,
					sections: Array.from(sectionMap.entries()).map(([section, studentMap]) => ({
						section,
						students: Array.from(studentMap.values()),
					})),
				})),
			}));
		}

		if (!groups.length) {
			container.innerHTML = '<p class="muted">No force-approved items found.</p>';
			return;
		}

		let html = '<div style="display:flex;flex-direction:column;gap:10px;">';
		groups.forEach((dept) => {
			html += `<details class="card" open><summary style="cursor:pointer;font-weight:700;">Department: ${dept.department}</summary>`;
			(dept.years || []).forEach((yearGroup) => {
				html += `<details class="card" style="margin-top:8px;"><summary style="cursor:pointer;font-weight:600;">Year: ${yearGroup.year}</summary>`;
				(yearGroup.sections || []).forEach((sectionGroup) => {
					html += `<details class="card" style="margin-top:8px;"><summary style="cursor:pointer;font-weight:600;">Section: ${sectionGroup.section}</summary>`;
					html += '<div class="table-responsive" style="margin-top:8px;"><table><tr><th>Student Name</th><th>Subject Name</th></tr>';
					(sectionGroup.students || []).forEach((stu) => {
						const subjects = Array.isArray(stu.subjects) ? stu.subjects : [];
						if (!subjects.length) {
							html += `<tr><td>${stu.studentName || '-'}</td><td>-</td></tr>`;
							return;
						}

						html += `<tr><td><strong>${stu.studentName || '-'}</strong></td><td>${subjects[0].subjectName || '-'}</td></tr>`;
						for (let i = 1; i < subjects.length; i += 1) {
							html += `<tr><td></td><td>${subjects[i].subjectName || '-'}</td></tr>`;
						}
					});
					html += '</table></div>';
					html += '</details>';
				});
				html += '</details>';
			});
			html += '</details>';
		});
		html += '</div>';
		container.innerHTML = html;
	} catch (err) {
		console.error('Failed to load HOD force-approved items', err);
		container.innerHTML = `<div class="alert">Failed to load data</div>`;
	}
};

