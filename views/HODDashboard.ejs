					<style>
						.btn-sm { padding: 4px 8px !important; font-size: 0.85em !important; }
					</style>

					<script>
						function addEditSectionRow(formId, e) {
							e.preventDefault();
							const container = document.getElementById('sectionContainer-' + formId);
							const row = document.createElement('div');
							row.style.display = 'flex'; row.style.gap = '6px'; row.style.alignItems = 'center'; row.style.marginBottom = '6px';
							row.innerHTML = `
								<input form="${formId}" type="text" name="sectionNames" placeholder="Sec" style="flex: 0.2;" />
								<select form="${formId}" name="sectionFacultyIds" style="flex: 1;">
									<option value="">Select faculty</option>
									<% faculties.forEach(function(f){ %>
									<option value="<%= f.facultyId %>"><%= f.name %> (<%= f.facultyId %>)</option>
									<% }) %>
								</select>
								<button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.remove();" style="flex: 0.15;">Remove</button>
							`;
							container.appendChild(row);
						}

						const clearanceForm = document.getElementById('hod-clearance-search-form');
						const clearanceRoll = document.getElementById('hod-clearance-roll');
						const clearanceResult = document.getElementById('hod-clearance-result');
						const escapeHtml = (value) => String(value == null ? '' : value)
							.replace(/&/g, '&amp;')
							.replace(/</g, '&lt;')
							.replace(/>/g, '&gt;')
							.replace(/"/g, '&quot;')
							.replace(/'/g, '&#39;');
						const getStatusTone = (status) => {
							const normalized = String(status || '').toLowerCase();
							if (normalized.includes('approved')) {
								return { bg: '#dcfce7', fg: '#166534', border: '#86efac' };
							}
							if (normalized.includes('rejected') || normalized.includes('denied')) {
								return { bg: '#fee2e2', fg: '#991b1b', border: '#fca5a5' };
							}
							if (normalized.includes('partial')) {
								return { bg: '#dbeafe', fg: '#1e3a8a', border: '#93c5fd' };
							}
							return { bg: '#fef3c7', fg: '#92400e', border: '#fcd34d' };
						};
						const renderStatusPill = (status) => {
							const label = status || 'Pending';
							const tone = getStatusTone(label);
							return `<span style="display:inline-block;padding:2px 10px;border-radius:999px;border:1px solid ${tone.border};background:${tone.bg};color:${tone.fg};font-weight:600;font-size:12px;line-height:1.5;">${escapeHtml(label)}</span>`;
						};
						if (clearanceForm && clearanceRoll && clearanceResult) {
							clearanceForm.addEventListener('submit', async (e) => {
								e.preventDefault();
								const rollNumber = clearanceRoll.value.trim();
								if (!rollNumber) return;
								clearanceResult.innerHTML = '<p class="muted">Searching...</p>';
								try {
									const response = await fetch('/api/student/search-status', {
										method: 'POST',
										headers: { 'Content-Type': 'application/json' },
										body: JSON.stringify({ rollNumber }),
									});
									const data = await response.json();
									if (!response.ok) throw new Error(data.error || 'Unable to fetch status');
									const student = data.student || {};
									const mentorInfo = data.mentorInfo || null;
									const objectiveInfo = data.objectiveInfo || null;

									const subjectsHtml = (data.subjects || []).length
										? `
											<table style="margin-top:12px;">
												<tr>
													<th>Subject code</th><th>Subject name</th><th>Faculty</th><th>Assignment 1</th><th>Assignment 2</th><th>Remarks</th>
												</tr>
												${(data.subjects || []).map((s) => `
													<tr>
														<td>${escapeHtml(s.subjectCode || '-')}</td>
														<td>${escapeHtml(s.subjectName || '-')}</td>
														<td>${escapeHtml(s.facultyName || '-')}</td>
														<td>${renderStatusPill(s.assignment1 ? 'Approved' : 'Pending')}</td>
														<td>${renderStatusPill(s.assignment2 ? 'Approved' : 'Pending')}</td>
														<td>${escapeHtml(s.facultyNote || '-')}</td>
													</tr>
												`).join('')}
											</table>`
										: '<p class="muted">No subject clearance records found.</p>';

									const mentorHtml = mentorInfo
										? `
											<div class="card" style="margin-top:12px;">
												<h3>Mentor status</h3>
												<p><strong>Mentor:</strong> ${escapeHtml(mentorInfo.mentorName || mentorInfo.mentorFacultyId || '-')}</p>
												<p><strong>${escapeHtml(mentorInfo.label1 || 'Assignment 1')}:</strong> ${renderStatusPill(mentorInfo.assignment1 ? 'Approved' : 'Pending')}</p>
												<p><strong>${escapeHtml(mentorInfo.label2 || 'Assignment 2')}:</strong> ${renderStatusPill(mentorInfo.assignment2 ? 'Approved' : 'Pending')}</p>
												<p><strong>Status:</strong> ${renderStatusPill(mentorInfo.status || '-')}</p>
											</div>`
										: '';

									const objectiveHtml = (objectiveInfo && objectiveInfo.objectives && objectiveInfo.objectives.length)
										? `
											<div class="card" style="margin-top:12px;">
												<h3>Objective approvals</h3>
												<p><strong>Overall status:</strong> ${renderStatusPill(objectiveInfo.status || 'Pending Faculty')}</p>
												<table style="margin-top:8px;">
													<tr>
														<th>Objective</th>
														<th>Faculty</th>
														<th>Status</th>
													</tr>
													${(objectiveInfo.objectives || []).map((obj) => `
														<tr>
															<td>${escapeHtml(obj.name || '-')}</td>
															<td>${escapeHtml(obj.facultyName || obj.facultyId || '-')}</td>
															<td>${renderStatusPill(obj.approved ? 'Approved' : (obj.status || 'Pending Faculty'))}</td>
														</tr>
													`).join('')}
												</table>
											</div>`
										: '';

									clearanceResult.hidden = false;
									clearanceResult.innerHTML = `
										<div class="card">
											<div class="flex-between">
												<h3>${escapeHtml(student.name || 'Student')} (${escapeHtml(data.rollNumber || rollNumber)})</h3>
												<span class="badge">${escapeHtml(student.branch || '-')}</span>
											</div>
											<p class="muted" style="margin-top:8px;">Department: ${escapeHtml(student.department || '-')} | Year: ${escapeHtml(student.year || '-')} | Semester: ${escapeHtml(student.semester || '-')}</p>
											${subjectsHtml}
											${mentorHtml}
											${objectiveHtml}
										</div>`;
									clearanceResult.scrollIntoView({ behavior: 'smooth', block: 'start' });
								} catch (err) {
									clearanceResult.innerHTML = `<div class="alert">${err.message || 'Search failed'}</div>`;
								}
							});
						}
					</script>
				</div>
			</div>

			<div class="panel" data-panel="manage-mentors">
