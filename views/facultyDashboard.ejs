<% const pageTitle = 'Faculty Dashboard'; %>
<%- include('partials/header', { title: pageTitle }) %>

<div class="layout-wrap">
    <aside class="sidebar">
        <h2>Faculty</h2>
        <a href="#pending" data-target="pending" class="active">Dashboard</a>
        <a href="#student-data" data-target="student-data">Subject-wise approvals</a>
        <a href="#mentor-subject-data" data-target="mentor-subject-data">Mentor approvals</a>
        <a href="#objective-data" data-target="objective-data">Objective approvals</a>
        <a href="#mentee-data" data-target="mentee-data">Mentees data</a>
        <a href="#profile" data-target="profile">Profile</a>
                <% if (subjectGroups && subjectGroups.length) { %>
                    <h2 style="margin-top:16px;font-size:0.9rem;opacity:0.85;">Your subjects</h2>
                    <% subjectGroups.forEach(function(group){ %>
                        <a href="#student-data" data-target="student-data" data-subject="<%= group.subjectCode %>">
                            <%= group.subjectCode %><%= group.subjectName ? ' — ' + group.subjectName : '' %>
                        </a>
                    <% }); %>
                <% } %>
        <form action="/logout" method="POST">
            <button type="submit" class="link-btn logout">Logout</button>
        </form>
    </aside>

    <section class="content stack">
        <div class="panel active" data-panel="pending">
            <div class="flex-between">
                <h1 id="pending">Approvals analytics</h1>
                <span class="badge" id="faculty-actionable-pending-badge"><%= (facultyAnalytics && facultyAnalytics.overall ? facultyAnalytics.overall.actionablePending : pending.length) %> actionable pending</span>
            </div>

            <div class="card" style="margin-top:12px;">
                <% const analytics = facultyAnalytics || { overall: { total: 0, students: 0, approved: 0, pending: 0, denied: 0, actionablePending: 0, approvalRate: 0 }, categories: [] }; %>
                <div class="grid two" style="gap:12px;">
                    <div class="card" style="margin:0;padding:14px;">
                        <p class="muted" style="margin:0 0 4px;">Total approval records</p>
                        <h2 style="margin:0;" id="faculty-total-records"><%= analytics.overall.total %></h2>
                    </div>
                    <div class="card" style="margin:0;padding:14px;">
                        <p class="muted" style="margin:0 0 4px;">Total students (category-wise sum)</p>
                        <h2 style="margin:0;" id="faculty-total-students"><%= analytics.overall.students %></h2>
                    </div>
                    <div class="card" style="margin:0;padding:14px;">
                        <p class="muted" style="margin:0 0 4px;">Approved</p>
                        <h2 style="margin:0;color:#0f766e;" id="faculty-approved-count"><%= analytics.overall.approved %></h2>
                    </div>
                    <div class="card" style="margin:0;padding:14px;">
                        <p class="muted" style="margin:0 0 4px;">Pending your action</p>
                        <h2 style="margin:0;color:#b45309;" id="faculty-actionable-pending-count"><%= analytics.overall.actionablePending %></h2>
                    </div>
                </div>

                <div class="grid two" style="gap:14px;margin-top:14px;">
                    <div class="card" style="margin:0;padding:14px;">
                        <h3 style="margin:0 0 10px;">Overall approval split (<span id="faculty-overall-approval-rate"><%= analytics.overall.approvalRate %></span>%)</h3>
                        <canvas id="faculty-overall-pie" width="220" height="220" style="max-width:220px;"></canvas>
                        <div class="muted" id="faculty-overall-legend" style="margin-top:10px;"></div>
                    </div>
                    <div class="card" style="margin:0;padding:14px;">
                        <h3 style="margin:0 0 10px;">Category workload split</h3>
                        <canvas id="faculty-category-pie" width="220" height="220" style="max-width:220px;"></canvas>
                        <div class="muted" id="faculty-category-legend" style="margin-top:10px;"></div>
                    </div>
                </div>

                <div style="margin-top:14px;">
                    <table>
                        <tr>
                            <th>Category</th>
                            <th>Total records</th>
                            <th>Total students</th>
                            <th>Approved</th>
                            <th>Pending</th>
                            <th>Denied</th>
                            <th>Actionable pending</th>
                            <th>Approval %</th>
                        </tr>
                        <tbody id="faculty-analytics-categories-body">
                        <% analytics.categories.forEach(function(c){ %>
                            <tr>
                                <td><%= c.label %></td>
                                <td><%= c.total %></td>
                                <td><%= c.students %></td>
                                <td><%= c.approved %></td>
                                <td><%= c.pending %></td>
                                <td><%= c.denied %></td>
                                <td><%= c.actionablePending %></td>
                                <td><%= c.approvalRate %>%</td>
                            </tr>
                        <% }); %>
                        </tbody>
                    </table>
                </div>

                <details style="margin-top:14px;">
                    <summary style="cursor:pointer;font-weight:600;">Open actionable pending list (<%= pending.length %>)</summary>
                    <% if (!pending.length) { %>
                        <p class="muted" style="margin-top:10px;">No general pending requests require review right now.</p>
                    <% } else { %>
                        <div style="margin-top:10px;" data-backup-scope="pending">
                            <div style="display:flex;justify-content:flex-end;margin-bottom:10px;">
                                <button type="button" class="btn btn-outline-primary btn-sm faculty-backup-save-btn" data-save-scope="pending">Backup save all</button>
                            </div>
                            <table>
                                <tr>
                                    <th>Student</th>
                                    <th>Department</th>
                                    <th>Reason</th>
                                    <th>Actions</th>
                                </tr>
                                <% pending.forEach((r) => { %>
                                <tr data-request-id="<%= r.id %>">
                                    <td><%= r.studentName %></td>
                                    <td><%= r.department %></td>
                                    <td><%= r.reason %></td>
                                    <td>
                                        <span class="faculty-request-status-text" style="display:none;"><%= r.status || 'Pending Faculty' %></span>
                                        <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
                                            <label style="display:inline-flex;gap:6px;align-items:center;cursor:pointer;">
                                                <input type="checkbox" class="faculty-request-status-toggle" data-request-id="<%= r.id %>" data-action="approve" <%= r.status === 'Approved' ? 'checked' : '' %> />
                                                <span>Approve</span>
                                            </label>
                                            <label style="display:inline-flex;gap:6px;align-items:center;cursor:pointer;">
                                                <input type="checkbox" class="faculty-request-status-toggle" data-request-id="<%= r.id %>" data-action="deny" <%= r.status === 'Rejected by Faculty' ? 'checked' : '' %> />
                                                <span>Deny</span>
                                            </label>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                            </table>
                        </div>
                    <% } %>
                </details>

                <script id="faculty-analytics-data" type="application/json"><%- JSON.stringify(analytics) %></script>
            </div>
        </div>

        <div class="panel" data-panel="student-data">
            <div class="card">
                <div class="flex-between">
                    <h2 id="student-data">Subject wise Faculty Approval Information</h2>
                    <span class="badge"><%= subjectGroups && subjectGroups.length ? subjectGroups.length + ' subjects' : 'No subjects' %></span>
                </div>

                <div class="grid two" style="margin-top:12px;">
                    <label class="field">
                        <span>Search in subject approvals</span>
                        <input type="text" id="faculty-subject-search" placeholder="Search by name, roll number, year, section, department" />
                    </label>
                </div>

                <% if (!subjectGroups || !subjectGroups.length) { %>
                    <p class="muted">No subject-wise approvals available yet.</p>
                <% } else { %>
                    <div class="faculty-bulk-assignments">
                        <input type="hidden" name="subjectCode" id="bulk-subject-code" value="" />
                        <% subjectGroups.forEach(function(group){ %>
                            <div class="card subject-group-card" data-subject="<%= group.subjectCode %>" style="margin-top:16px;">
                                <div class="flex-between" style="gap:12px;align-items:flex-start;flex-wrap:wrap;">
                                    <h3><%= group.subjectName %> <small style="font-weight:400;color:#6b7280;">(<%= group.subjectCode || 'Code N/A' %>)</small></h3>
                                    <div style="display:flex;gap:8px;flex-wrap:wrap;">
                                        <button type="button" class="btn btn-outline-primary btn-sm faculty-backup-save-btn" data-save-scope="subject">Backup save all</button>
                                        <form action="/faculty/requests/approve-all" method="POST">
                                            <input type="hidden" name="scope" value="subject" />
                                            <input type="hidden" name="subjectCode" value="<%= group.subjectCode || '' %>" />
                                            <input type="hidden" name="bulkAction" value="approve" />
                                            <input type="hidden" name="redirectPanel" value="student-data" />
                                            <button type="submit" class="btn btn-accent btn-sm">Approve all</button>
                                        </form>
                                        <form action="/faculty/requests/approve-all" method="POST">
                                            <input type="hidden" name="scope" value="subject" />
                                            <input type="hidden" name="subjectCode" value="<%= group.subjectCode || '' %>" />
                                            <input type="hidden" name="bulkAction" value="revoke" />
                                            <input type="hidden" name="redirectPanel" value="student-data" />
                                            <button type="submit" class="btn btn-outline-primary btn-sm">Revoke all</button>
                                        </form>
                                    </div>
                                </div>
                                <table>
                                    <tr>
                                        <th>S.No</th>
                                        <th>Roll Number</th>
                                        <th>Name</th>
                                        <th>Year</th>
                                        <th>Section</th>
                                        <th>Department</th>
                                        <th>Assignment 1</th>
                                        <th>Assignment 2</th>
                                        <th>Remarks</th>
                                    </tr>
                                    <% group.rows.forEach(function(r, idx){ %>
                                        <tr class="faculty-subject-row" data-year="<%= r.year || '' %>" data-section="<%= r.section || '' %>" data-department="<%= r.department || '' %>">
                                            <td><%= idx + 1 %></td>
                                            <td><%= r.rollNumber || '-' %></td>
                                            <td><%= r.studentName || '-' %></td>
                                            <td><%= r.year || '-' %></td>
                                            <td><%= r.section || '-' %></td>
                                            <td><%= r.department || '-' %></td>
                                            <td style="text-align:center;">
                                                <input type="checkbox" name="assignments[<%= r.id %>][assignment1]" <%= r.assignment1 ? 'checked' : '' %> />
                                            </td>
                                            <td style="text-align:center;">
                                                <input type="checkbox" name="assignments[<%= r.id %>][assignment2]" <%= r.assignment2 ? 'checked' : '' %> />
                                            </td>
                                            <td>
                                                <input
                                                    type="text"
                                                    name="assignments[<%= r.id %>][facultyNote]"
                                                    value="<%= r.facultyNote || '' %>"
                                                    placeholder="Remarks"
                                                    style="width:100%;max-width:260px;"
                                                />
                                            </td>
                                        </tr>
                                    <% }); %>
                                </table>
                            </div>
                        <% }); %>
                        <div style="margin-top:16px;display:flex;justify-content:space-between;align-items:center;">
                            <p style="color:#6b7280;font-size:0.9rem;margin:0;"><em>Auto-saves on each change</em></p>
                            <span class="muted">Manual backup save is available on each row</span>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="panel" data-panel="mentor-subject-data">
            <div class="card">
                <div class="flex-between">
                    <h2 id="mentor-subject-data">Mentor subject approvals</h2>
                    <span class="badge"><%= mentorSubjectRequests && mentorSubjectRequests.length ? mentorSubjectRequests.length + ' requests' : 'No mentor requests' %></span>
                </div>

                <div class="grid two" style="margin-top:12px;">
                    <label class="field">
                        <span>Search in mentor approvals</span>
                        <input type="text" id="faculty-mentor-search" placeholder="Search by name, roll number, year, section, department" />
                    </label>
                </div>

                <div style="margin:10px 0 14px;display:flex;gap:8px;flex-wrap:wrap;">
                    <form action="/faculty/requests/approve-all" method="POST">
                        <input type="hidden" name="scope" value="mentor" />
                        <input type="hidden" name="redirectPanel" value="mentor-subject-data" />
                        <button type="submit" class="btn btn-outline-primary">Approve all mentor requests</button>
                    </form>
                </div>

                <% if (!mentorSubjectRequests || !mentorSubjectRequests.length) { %>
                    <p class="muted">No mentor subject requests pending for your mentees.</p>
                <% } else { %>
                    <div style="display:flex;flex-wrap:wrap;gap:8px;margin:10px 0 14px;">
                        <button type="button" class="btn btn-outline-primary mentor-subject-chip active" data-mentor-subject="__all">All subjects</button>
                        <% mentorSubjectRequestGroups.forEach(function(subjectGroup){ const subjectFilter = subjectGroup.subjectCode || subjectGroup.subjectName; %>
                            <button type="button" class="btn btn-outline-primary mentor-subject-chip" data-mentor-subject="<%= subjectFilter %>">
                                <%= subjectGroup.subjectName || subjectGroup.subjectCode || 'Mentor Subject' %>
                            </button>
                        <% }); %>
                    </div>

                    <div class="stack" style="gap:14px;">
                        <% mentorSubjectRequestGroups.forEach(function(subjectGroup){ const subjectFilter = subjectGroup.subjectCode || subjectGroup.subjectName; %>
                            <details class="card mentor-subject-card" data-mentor-subject="<%= subjectFilter %>" style="margin:0;">
                                <summary class="flex-between" style="gap:10px;align-items:flex-start;cursor:pointer;list-style:none;">
                                    <h3 style="margin:0;"><%= subjectGroup.subjectName || subjectGroup.subjectCode || '-' %></h3>
                                    <span style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                                        <span class="badge"> <%= subjectGroup.years.length %> year group(s)</span>
                                        <button type="button" class="btn btn-outline-primary btn-sm faculty-backup-save-btn" data-save-scope="mentor">Backup save all</button>
                                    </span>
                                </summary>

                                <div class="stack" style="margin-top:12px;gap:12px;">
                                    <% subjectGroup.years.forEach(function(group){ %>
                                        <details class="card mentor-year-card" style="margin:0;padding:0;border:1px solid #e5e7eb;border-radius:6px;">
                                            <summary style="cursor:pointer;padding:14px;font-weight:600;list-style:none;user-select:none;">Year: <%= group.year %></summary>
                                            <div style="padding:0 14px 14px;">
                                                <div class="stack" style="gap:10px;">
                                                    <% group.sections.forEach(function(sectionGroup){ %>
                                                        <details class="card mentor-section-card" style="margin:0;padding:0;border:1px solid #e5e7eb;border-radius:6px;">
                                                            <summary style="cursor:pointer;padding:12px;font-weight:600;list-style:none;user-select:none;color:#666;">Section: <%= sectionGroup.section %></summary>
                                                            <div style="padding:0 12px 12px;">

                                                            <% sectionGroup.departments.forEach(function(deptGroup){ %>
                                                                <div class="muted" style="margin:6px 0;font-weight:600;">Department: <%= deptGroup.department %></div>
                                                                <table style="margin-top:6px;">
                                                                    <tr>
                                                                        <th>Student</th>
                                                                        <th>Roll number</th>
                                                                        <th>Branch / Year</th>
                                                                        <th>Status</th>
                                                                        <th>Action</th>
                                                                    </tr>
                                                                    <% deptGroup.rows.forEach(function(r){ %>
                                                                    <tr class="faculty-mentor-row" data-request-id="<%= r.id %>" data-year="<%= r.year || '' %>" data-section="<%= r.section || '' %>" data-department="<%= r.department || '' %>" data-mentor-subject="<%= subjectFilter %>">
                                                                        <td><%= r.studentName || '-' %></td>
                                                                        <td><%= r.rollNumber || '-' %></td>
                                                                        <td>
                                                                            <%= r.branch || '-' %>
                                                                            <% if (r.year) { %> • Year <%= r.year %><% } %>
                                                                            <% if (r.semester) { %> • Sem <%= r.semester %><% } %>
                                                                        </td>
                                                                        <td><span class="faculty-request-status-text"><%= r.status || '-' %></span></td>
                                                                        <td>
                                                                            <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
                                                                                <label style="display:inline-flex;gap:6px;align-items:center;cursor:pointer;">
                                                                                    <input type="checkbox" class="faculty-request-status-toggle" data-request-id="<%= r.id %>" data-action="approve" <%= r.status === 'Approved' ? 'checked' : '' %> />
                                                                                    <span>Approve</span>
                                                                                </label>
                                                                                <label style="display:inline-flex;gap:6px;align-items:center;cursor:pointer;">
                                                                                    <input type="checkbox" class="faculty-request-status-toggle" data-request-id="<%= r.id %>" data-action="deny" <%= r.status === 'Rejected by Faculty' ? 'checked' : '' %> />
                                                                                    <span>Deny</span>
                                                                                </label>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                    <% }); %>
                                                                </table>
                                                            <% }); %>
                                                            </div>
                                                        </details>
                                                    <% }); %>
                                                </div>
                                            </div>
                                        </details>
                                    <% }); %>
                                </div>
                            </details>
                        <% }); %>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="panel" data-panel="objective-data">
            <div class="card">
                <div class="flex-between">
                    <h2 id="objective-data">Objective approvals</h2>
                    <span class="badge"><%= objectiveGroups && objectiveGroups.length ? objectiveGroups.length + ' objectives' : 'No objective approvals' %></span>
                </div>

                <div class="grid two" style="margin-top:12px;">
                    <label class="field">
                        <span>Search in objective approvals</span>
                        <input type="text" id="faculty-objective-search" placeholder="Search by name, roll number, year, section, department" />
                    </label>
                </div>

                <div style="margin:10px 0 14px;display:flex;gap:8px;flex-wrap:wrap;">
                    <form action="/faculty/requests/approve-all" method="POST">
                        <input type="hidden" name="scope" value="objective" />
                        <input type="hidden" name="redirectPanel" value="objective-data" />
                        <button type="submit" class="btn btn-outline-primary">Approve all objectives</button>
                    </form>
                </div>

                <% if (!objectiveGroups || !objectiveGroups.length) { %>
                    <p class="muted">No objective approvals are assigned to you right now.</p>
                <% } else { %>
                    <div style="display:flex;flex-wrap:wrap;gap:8px;margin:10px 0 14px;">
                        <button type="button" class="btn btn-outline-primary objective-chip active" data-objective="__all">All objectives</button>
                        <% objectiveGroups.forEach(function(group){ %>
                            <button type="button" class="btn btn-outline-primary btn-sm objective-chip" data-objective="<%= group.code %>">
                                <%= group.name %>
                                <span class="badge" style="margin-left:6px;"><%= group.rows.length %></span>
                            </button>
                        <% }); %>
                    </div>

                    <% objectiveGroups.forEach(function(group){ %>
                        <details class="card objective-group-card" id="objective-<%= group.code %>" data-objective="<%= group.code %>" style="margin-top:12px;">
                            <summary class="flex-between" style="cursor:pointer;list-style:none;gap:12px;align-items:flex-start;flex-wrap:wrap;">
                                <span>
                                    <strong><%= group.name %></strong>
                                    <% if (group.code) { %><span class="muted" style="margin-left:6px;"><%= group.code.replace('OBJECTIVE::', '') %></span><% } %>
                                </span>
                                <span style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                                    <span class="badge"><%= group.rows.length %> students</span>
                                    <button type="button" class="btn btn-outline-primary btn-sm faculty-backup-save-btn" data-save-scope="objective">Backup save all</button>
                                    <form action="/faculty/requests/approve-all" method="POST" style="display:inline;">
                                        <input type="hidden" name="scope" value="objective" />
                                        <input type="hidden" name="objectiveCode" value="OBJECTIVE::<%= group.code %>" />
                                        <input type="hidden" name="redirectPanel" value="objective-data" />
                                        <button type="submit" class="btn btn-outline-primary btn-sm">Approve all in this objective</button>
                                    </form>
                                </span>
                            </summary>

                            <div style="margin-top:12px;">
                                <% if (!group.rows.length) { %>
                                    <p class="muted">No students mapped yet.</p>
                                <% } else { %>
                                    <% const groupedRows = group.groupedRows || []; %>
                                    <div class="stack" style="gap:12px;">
                                        <% groupedRows.forEach(function(yearGroup){ %>
                                            <details class="card objective-year-card" style="margin:0;padding:0;border:1px solid #e5e7eb;border-radius:6px;">
                                                <summary style="cursor:pointer;padding:14px;font-weight:600;list-style:none;user-select:none;">Year: <%= yearGroup.year %></summary>
                                                <div style="padding:0 14px 14px;">
                                                    <div class="stack" style="gap:10px;">
                                                        <% yearGroup.sections.forEach(function(sectionGroup){ %>
                                                            <details class="card objective-section-card" style="margin:0;padding:0;border:1px solid #e5e7eb;border-radius:6px;">
                                                                <summary style="cursor:pointer;padding:12px;font-weight:600;list-style:none;user-select:none;color:#666;">Section: <%= sectionGroup.section %></summary>
                                                                <div style="padding:0 12px 12px;">
                                                                <% sectionGroup.departments.forEach(function(deptGroup){ %>
                                                                    <div class="card objective-department-card" style="margin:0 0 8px;padding:10px;">
                                                                        <div class="muted" style="margin:0 0 8px;font-weight:600;">Department: <%= deptGroup.department %></div>
                                                                        <table class="objective-department-table" style="margin-top:4px;">
                                                                            <tr>
                                                                                <th>Student</th>
                                                                                <th>Roll number</th>
                                                                                <th>Branch / Year</th>
                                                                                <th>Status</th>
                                                                                <th>Action</th>
                                                                            </tr>
                                                                            <% deptGroup.rows.forEach(function(r){ %>
                                                                            <tr class="faculty-objective-row" data-request-id="<%= r.id %>" data-year="<%= r.year || '' %>" data-section="<%= r.section || '' %>" data-department="<%= r.department || '' %>">
                                                                                <td><%= r.studentName || '-' %></td>
                                                                                <td><%= r.rollNumber || '-' %></td>
                                                                                <td>
                                                                                    <%= r.branch || '-' %>
                                                                                    <% if (r.year) { %> • Year <%= r.year %><% } %>
                                                                                    <% if (r.semester) { %> • Sem <%= r.semester %><% } %>
                                                                                </td>
                                                                                <td><span class="faculty-request-status-text"><%= r.status || '-' %></span></td>
                                                                                <td>
                                                                                    <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
                                                                                        <label style="display:inline-flex;gap:6px;align-items:center;cursor:pointer;">
                                                                                            <input type="checkbox" class="faculty-request-status-toggle" data-request-id="<%= r.id %>" data-action="approve" <%= r.status === 'Approved' ? 'checked' : '' %> />
                                                                                            <span>Approve</span>
                                                                                        </label>
                                                                                        <label style="display:inline-flex;gap:6px;align-items:center;cursor:pointer;">
                                                                                            <input type="checkbox" class="faculty-request-status-toggle" data-request-id="<%= r.id %>" data-action="deny" <%= r.status === 'Rejected by Faculty' ? 'checked' : '' %> />
                                                                                            <span>Deny</span>
                                                                                        </label>
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                            <% }); %>
                                                                        </table>
                                                                    </div>
                                                                <% }); %>
                                                                </div>
                                                            </details>
                                                        <% }); %>
                                                    </div>
                                                </div>
                                            </details>
                                        <% }); %>
                                    </div>
                                <% } %>
                            </div>
                        </details>
                    <% }); %>
                <% } %>
            </div>
        </div>

        <div class="panel" data-panel="mentee-data">
            <div class="card">
                <div class="flex-between">
                    <h2 id="mentee-data">Assigned mentees</h2>
                    <span class="badge"><%= assignedMentees && assignedMentees.length ? assignedMentees.length + ' mentees' : 'No mentees' %></span>
                </div>
                <% if (assignedMentees && assignedMentees.length) { %>
                <table style="margin-top:12px;">
                    <tr>
                        <th>Name</th>
                        <th>Roll number</th>
                        <th>Branch / Year</th>
                        <th>Department</th>
                        <th>Section</th>
                        <th>Mentor notes</th>
                    </tr>
                    <% assignedMentees.forEach(function(s){ %>
                    <tr>
                        <td><%= s.name || '-' %></td>
                        <td><%= s.rollNumber || '-' %></td>
                        <td>
                            <%= s.branch || '-' %>
                            <% if (s.year) { %> • Year <%= s.year %><% } %>
                            <% if (s.semester) { %> • Sem <%= s.semester %><% } %>
                        </td>
                        <td><%= s.department || '-' %></td>
                        <td><%= s.section || '-' %></td>
                        <td><%= s.mentorNotes || '-' %></td>
                    </tr>
                    <% }); %>
                </table>
                <% } else { %>
                <p class="muted">No mentees are mapped to your faculty ID yet.</p>
                <% } %>

                <div style="margin-top:18px;" class="flex-between">
                    <h3 style="margin:0;">Mentor approvals</h3>
                    <span class="badge"><%= mentorSubjectRequests && mentorSubjectRequests.length ? mentorSubjectRequests.length + ' requests' : 'No mentor requests' %></span>
                </div>

                <div style="margin:10px 0 12px;display:flex;gap:8px;flex-wrap:wrap;">
                    <button type="button" class="btn btn-outline-primary btn-sm faculty-backup-save-btn" data-save-scope="mentee">Backup save all</button>
                    <form action="/faculty/requests/approve-all" method="POST">
                        <input type="hidden" name="scope" value="mentor" />
                        <input type="hidden" name="redirectPanel" value="mentee-data" />
                        <button type="submit" class="btn btn-outline-primary btn-sm">Approve all mentee mentor requests</button>
                    </form>
                </div>

                <% if (!mentorSubjectRequests || !mentorSubjectRequests.length) { %>
                <p class="muted">No mentor requests pending for your mentees.</p>
                <% } else { %>
                <% const menteeDepts = []; mentorSubjectRequests.forEach(function(r){ if (r.department && !menteeDepts.includes(r.department)) menteeDepts.push(r.department); }); %>
                <div style="margin:8px 0; display:flex; flex-wrap:wrap; gap:8px;">
					<button type="button" class="btn btn-outline-primary mentee-dept-chip active" data-dept="__all">All</button>
					<% menteeDepts.forEach(function(d){ %>
						<button type="button" class="btn btn-outline-primary mentee-dept-chip" data-dept="<%= d %>"><%= d %></button>
					<% }); %>
				</div>
                <table id="mentee-table">
                    <tr>
                        <th>Name</th>
                        <th>Roll number</th>
                        <th>Branch / Year</th>
                        <th>Department</th>
                        <th>Section</th>
                        <th>Mentor subject</th>
                        <th>Status</th>
                    </tr>
                    <% mentorSubjectRequests.forEach((r) => { %>
                    <tr data-dept="<%= r.department || '' %>" data-request-id="<%= r.id %>">
                        <td><%= r.studentName %></td>
                        <td><%= r.rollNumber %></td>
                        <td>
                            <%= r.branch || '-' %>
                            <% if (r.year) { %> • Year <%= r.year %><% } %>
                            <% if (r.semester) { %> • Sem <%= r.semester %><% } %>
                        </td>
                        <td><%= r.department || '-' %></td>
                        <td><%= r.section || '-' %></td>
                        <td><%= r.subjectName || r.reason || '-' %></td>
                        <td>
                            <span class="faculty-request-status-text"><%= r.status || '-' %></span>
                            <div style="margin-top:6px;display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
                                <label style="display:inline-flex;gap:6px;align-items:center;cursor:pointer;">
                                    <input type="checkbox" class="faculty-request-status-toggle" data-request-id="<%= r.id %>" data-action="approve" <%= r.status === 'Approved' ? 'checked' : '' %> />
                                    <span>Approve</span>
                                </label>
                                <label style="display:inline-flex;gap:6px;align-items:center;cursor:pointer;">
                                    <input type="checkbox" class="faculty-request-status-toggle" data-request-id="<%= r.id %>" data-action="deny" <%= r.status === 'Rejected by Faculty' ? 'checked' : '' %> />
                                    <span>Deny</span>
                                </label>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </table>
                <% } %>
            </div>
        </div>

        <div class="panel" data-panel="profile">
            <div class="card" id="profile">
                <div class="flex-between">
                    <h2>Profile</h2>
                    <span class="badge">Update your info</span>
                </div>

                <% if (profileError) { %>
                  <div class="alert"><%= profileError %></div>
                <% } %>
                <% if (profileSuccess) { %>
                  <div class="alert success"><%= profileSuccess %></div>
                <% } %>

                <form action="/faculty/profile" method="POST" class="stack">
                    <label class="field">
                        <span>Name</span>
                        <input type="text" name="name" value="<%= self?.name || '' %>" placeholder="Enter name" />
                    </label>
                    <label class="field">
                        <span>Faculty ID</span>
                        <input type="text" name="facultyId" value="<%= self?.facultyId || '' %>" placeholder="Enter faculty ID" />
                    </label>
                    <label class="field">
                        <span>New password</span>
                        <input type="password" name="password" placeholder="Leave blank to keep current" />
                    </label>
                    <p class="muted">Change any field and submit. Password updates are stored securely.</p>
                    <button type="submit" class="btn btn-accent">Save changes</button>
                </form>
            </div>
        </div>
    </section>
</div>

<script>
(() => {
    const links = document.querySelectorAll('.sidebar a[data-target]');
    const panels = document.querySelectorAll('.panel');
    const bulkSubjectInput = document.getElementById('bulk-subject-code');
    const subjectSearchInput = document.getElementById('faculty-subject-search');
    const mentorSearchInput = document.getElementById('faculty-mentor-search');
    const objectiveSearchInput = document.getElementById('faculty-objective-search');
    const mentorSubjectChips = Array.from(document.querySelectorAll('.mentor-subject-chip'));
    const mentorSubjectCards = Array.from(document.querySelectorAll('.mentor-subject-card'));
    const objectiveChips = Array.from(document.querySelectorAll('.objective-chip'));
    const objectiveCards = Array.from(document.querySelectorAll('.objective-group-card'));
    let currentSubject = null;
    let currentMentorSubject = '__all';
    let currentObjective = '__all';
    const analyticsDataNode = document.getElementById('faculty-analytics-data');
    const analyticsActionableBadge = document.getElementById('faculty-actionable-pending-badge');
    const analyticsTotalRecords = document.getElementById('faculty-total-records');
    const analyticsTotalStudents = document.getElementById('faculty-total-students');
    const analyticsApprovedCount = document.getElementById('faculty-approved-count');
    const analyticsActionableCount = document.getElementById('faculty-actionable-pending-count');
    const analyticsOverallRate = document.getElementById('faculty-overall-approval-rate');
    const analyticsCategoriesBody = document.getElementById('faculty-analytics-categories-body');
    let analyticsData = null;

    const escapeHtmlText = (value) => String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

    if (analyticsDataNode && analyticsDataNode.textContent) {
        try {
            analyticsData = JSON.parse(analyticsDataNode.textContent);
        } catch (err) {
            analyticsData = null;
        }
    }

    const renderAnalyticsCategories = () => {
        if (!analyticsCategoriesBody || !analyticsData || !Array.isArray(analyticsData.categories)) return;

        analyticsCategoriesBody.innerHTML = analyticsData.categories.map((category) => `
            <tr>
                <td>${escapeHtmlText(category.label || '-')}</td>
                <td>${escapeHtmlText(category.total || 0)}</td>
                <td>${escapeHtmlText(category.students || 0)}</td>
                <td>${escapeHtmlText(category.approved || 0)}</td>
                <td>${escapeHtmlText(category.pending || 0)}</td>
                <td>${escapeHtmlText(category.denied || 0)}</td>
                <td>${escapeHtmlText(category.actionablePending || 0)}</td>
                <td>${escapeHtmlText(category.approvalRate || 0)}%</td>
            </tr>
        `).join('');
    };

    const syncAnalyticsDom = () => {
        if (!analyticsData || !analyticsData.overall) return;

        if (analyticsActionableBadge) {
            analyticsActionableBadge.textContent = `${analyticsData.overall.actionablePending || 0} actionable pending`;
        }
        if (analyticsTotalRecords) {
            analyticsTotalRecords.textContent = analyticsData.overall.total || 0;
        }
        if (analyticsTotalStudents) {
            analyticsTotalStudents.textContent = analyticsData.overall.students || 0;
        }
        if (analyticsApprovedCount) {
            analyticsApprovedCount.textContent = analyticsData.overall.approved || 0;
        }
        if (analyticsActionableCount) {
            analyticsActionableCount.textContent = analyticsData.overall.actionablePending || 0;
        }
        if (analyticsOverallRate) {
            analyticsOverallRate.textContent = analyticsData.overall.approvalRate || 0;
        }
        if (analyticsDataNode) {
            analyticsDataNode.textContent = JSON.stringify(analyticsData);
        }

        renderAnalyticsCategories();
        renderAnalyticsCharts();
    };

    const refreshFacultyAnalytics = async () => {
        try {
            const response = await fetch('/faculty/analytics/status', {
                headers: { 'Accept': 'application/json' },
            });
            if (!response.ok) return;
            const payload = await response.json();
            analyticsData = payload.analytics || analyticsData;
            syncAnalyticsDom();
        } catch (err) {
            // keep the dashboard usable even if refresh fails
        }
    };

    const renderPieChart = (canvasId, legendId, segments) => {
        const canvas = document.getElementById(canvasId);
        if (!canvas || !Array.isArray(segments) || !segments.length) return;

        const total = segments.reduce((sum, segment) => sum + (segment.value || 0), 0);
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        const width = canvas.width;
        const height = canvas.height;
        const centerX = width / 2;
        const centerY = height / 2;
        const radius = Math.min(centerX, centerY) - 10;

        ctx.clearRect(0, 0, width, height);

        if (!total) {
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius, 0, Math.PI * 2);
            ctx.fillStyle = '#e5e7eb';
            ctx.fill();
            ctx.closePath();

            const legend = document.getElementById(legendId);
            if (legend) legend.textContent = 'No data available yet.';
            return;
        }

        let startAngle = -Math.PI / 2;
        segments.forEach((segment) => {
            const value = segment.value || 0;
            if (!value) return;
            const sliceAngle = (value / total) * Math.PI * 2;

            ctx.beginPath();
            ctx.moveTo(centerX, centerY);
            ctx.arc(centerX, centerY, radius, startAngle, startAngle + sliceAngle);
            ctx.closePath();
            ctx.fillStyle = segment.color;
            ctx.fill();

            startAngle += sliceAngle;
        });

        // Donut hole for readability
        ctx.beginPath();
        ctx.arc(centerX, centerY, radius * 0.52, 0, Math.PI * 2);
        ctx.fillStyle = '#ffffff';
        ctx.fill();
        ctx.closePath();

        const legend = document.getElementById(legendId);
        if (legend) {
            legend.innerHTML = segments
                .filter((segment) => (segment.value || 0) > 0)
                .map((segment) => {
                    const pct = Math.round(((segment.value || 0) / total) * 100);
                    return `<span style="display:inline-flex;align-items:center;gap:6px;margin-right:12px;"><span style="display:inline-block;width:10px;height:10px;border-radius:999px;background:${segment.color};"></span>${segment.label}: ${segment.value} (${pct}%)</span>`;
                })
                .join('');
        }
    };

    const renderAnalyticsCharts = () => {
        if (!analyticsData || !analyticsData.overall) return;

        renderPieChart('faculty-overall-pie', 'faculty-overall-legend', [
            { label: 'Approved', value: analyticsData.overall.approved || 0, color: '#0f766e' },
            { label: 'Pending', value: analyticsData.overall.pending || 0, color: '#f59e0b' },
            { label: 'Denied', value: analyticsData.overall.denied || 0, color: '#dc2626' },
        ]);

        const categoryPalette = ['#2563eb', '#7c3aed', '#0891b2', '#ca8a04', '#16a34a', '#be123c'];
        const categorySegments = (analyticsData.categories || []).map((category, idx) => ({
            label: category.label || 'Category',
            value: category.total || 0,
            color: categoryPalette[idx % categoryPalette.length],
        }));

        renderPieChart('faculty-category-pie', 'faculty-category-legend', categorySegments);
    };

    if (analyticsData) {
        syncAnalyticsDom();
    }

    const wrapTablesForScroll = () => {
        document.querySelectorAll('.content table').forEach((table) => {
            if (table.closest('.table-responsive')) return;
            const wrapper = document.createElement('div');
            wrapper.className = 'table-responsive';
            table.parentNode.insertBefore(wrapper, table);
            wrapper.appendChild(table);
        });
    };

    const applySearch = (input, selector, afterFilter) => {
        if (!input) return;

        const update = () => {
            const query = (input.value || '').trim().toLowerCase();
            document.querySelectorAll(selector).forEach((row) => {
                const text = (row.textContent || '').toLowerCase();
                row.style.display = !query || text.includes(query) ? '' : 'none';
            });
            if (typeof afterFilter === 'function') {
                afterFilter(query);
            }
        };

        input.addEventListener('input', update);
        update();
    };

    const filterSubject = (subjectCode) => {
        const cards = document.querySelectorAll('.subject-group-card');
        if (!cards.length) return;

        if (!subjectCode) {
            cards.forEach((c) => {
                c.style.display = '';
            });
            return;
        }

        cards.forEach((c) => {
            const code = c.getAttribute('data-subject');
            c.style.display = code === subjectCode ? '' : 'none';
        });
    };

    const activate = (target, activeLink = null) => {
        panels.forEach((p) => p.classList.toggle('active', p.dataset.panel === target));

        // Only highlight the clicked link (or a chosen default),
        // instead of marking all links with the same data-target as active.
        links.forEach((l) => {
            const shouldBeActive = activeLink
                ? l === activeLink
                : (l.dataset.target === target && !l.dataset.subject);
            l.classList.toggle('active', shouldBeActive);
        });
        if (target === 'student-data') {
            // When hitting main "Subject-wise approvals" link, show all subjects
            const subject = activeLink && activeLink.getAttribute('data-subject');
            currentSubject = subject || null;
            if (bulkSubjectInput) {
                bulkSubjectInput.value = currentSubject || '';
            }
            filterSubject(currentSubject);
        }
  };

  links.forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
            const target = link.dataset.target;
            const subject = link.getAttribute('data-subject');
                        activate(target, link);
            if (target === 'student-data') {
                filterSubject(subject || null);
            }
    });
  });

    // Department-wise mentee filter in "Mentees data" panel
    const menteeDeptChips = Array.from(document.querySelectorAll('.mentee-dept-chip'));
    const menteeRows = Array.from(document.querySelectorAll('#mentee-table tr[data-dept]'));
    const filterMenteeDept = (dept) => {
        menteeRows.forEach((row) => {
            const rowDept = row.dataset.dept || '';
            row.style.display = !dept || dept === '__all' || rowDept === dept ? '' : 'none';
        });
    };
    if (menteeDeptChips.length && menteeRows.length) {
        menteeDeptChips.forEach((chip) => {
            chip.addEventListener('click', () => {
                const dept = chip.dataset.dept;
                menteeDeptChips.forEach((c) => c.classList.toggle('active', c === chip));
                filterMenteeDept(dept);
            });
        });
        filterMenteeDept('__all');
    }

    const filterMentorSubjectCards = (subjectKey) => {
        currentMentorSubject = subjectKey || '__all';
        mentorSubjectCards.forEach((card) => {
            const cardSubject = card.getAttribute('data-mentor-subject') || '';
            card.style.display = currentMentorSubject === '__all' || cardSubject === currentMentorSubject ? '' : 'none';
        });
    };

    if (mentorSubjectChips.length && mentorSubjectCards.length) {
        mentorSubjectChips.forEach((chip) => {
            chip.addEventListener('click', () => {
                const subjectKey = chip.dataset.mentorSubject || '__all';
                mentorSubjectChips.forEach((c) => c.classList.toggle('active', c === chip));
                filterMentorSubjectCards(subjectKey);
            });
        });
        filterMentorSubjectCards('__all');
    }

    const filterObjectiveCards = (objectiveKey) => {
        currentObjective = objectiveKey || '__all';
        objectiveCards.forEach((card) => {
            const cardObjective = card.getAttribute('data-objective') || '';
            card.style.display = currentObjective === '__all' || cardObjective === currentObjective ? '' : 'none';
        });
    };

    if (objectiveChips.length && objectiveCards.length) {
        objectiveChips.forEach((chip) => {
            chip.addEventListener('click', () => {
                const objectiveKey = chip.dataset.objective || '__all';
                objectiveChips.forEach((c) => c.classList.toggle('active', c === chip));
                filterObjectiveCards(objectiveKey);
            });
        });
        filterObjectiveCards('__all');
    }

    applySearch(subjectSearchInput, '.faculty-subject-row', () => {
        document.querySelectorAll('.subject-group-card').forEach((card) => {
            const rows = Array.from(card.querySelectorAll('.faculty-subject-row'));
            const hasVisibleRows = rows.some((row) => row.style.display !== 'none');
            card.style.display = hasVisibleRows ? '' : 'none';
        });
    });

    applySearch(mentorSearchInput, '.faculty-mentor-row', () => {
        document.querySelectorAll('.mentor-section-card').forEach((sectionCard) => {
            const tables = Array.from(sectionCard.querySelectorAll('table'));
            tables.forEach((table) => {
                const rows = Array.from(table.querySelectorAll('.faculty-mentor-row'));
                const hasVisibleRows = rows.some((row) => row.style.display !== 'none');
                table.style.display = hasVisibleRows ? '' : 'none';
            });

            const anyVisibleTable = tables.some((table) => table.style.display !== 'none');
            sectionCard.style.display = anyVisibleTable ? '' : 'none';
        });

        document.querySelectorAll('.mentor-year-card').forEach((yearCard) => {
            const sections = Array.from(yearCard.querySelectorAll('.mentor-section-card'));
            const hasVisibleSections = sections.some((section) => section.style.display !== 'none');
            yearCard.style.display = hasVisibleSections ? '' : 'none';
        });

        mentorSubjectCards.forEach((subjectCard) => {
            const years = Array.from(subjectCard.querySelectorAll('.mentor-year-card'));
            const hasVisibleYears = years.some((year) => year.style.display !== 'none');
            const subjectMatch = currentMentorSubject === '__all'
                || (subjectCard.getAttribute('data-mentor-subject') || '') === currentMentorSubject;
            subjectCard.style.display = hasVisibleYears && subjectMatch ? '' : 'none';
        });
    });

    applySearch(objectiveSearchInput, '.faculty-objective-row', () => {
        document.querySelectorAll('.objective-section-card').forEach((sectionCard) => {
            const tables = Array.from(sectionCard.querySelectorAll('.objective-department-table'));
            tables.forEach((table) => {
                const rows = Array.from(table.querySelectorAll('.faculty-objective-row'));
                const hasVisibleRows = rows.some((row) => row.style.display !== 'none');
                table.style.display = hasVisibleRows ? '' : 'none';
            });

            const anyVisibleTable = tables.some((table) => table.style.display !== 'none');
            sectionCard.style.display = anyVisibleTable ? '' : 'none';
        });

        document.querySelectorAll('.objective-year-card').forEach((yearCard) => {
            const sections = Array.from(yearCard.querySelectorAll('.objective-section-card'));
            const hasVisibleSections = sections.some((section) => section.style.display !== 'none');
            yearCard.style.display = hasVisibleSections ? '' : 'none';
        });

        document.querySelectorAll('.objective-group-card').forEach((groupCard) => {
            const years = Array.from(groupCard.querySelectorAll('.objective-year-card'));
            const hasVisibleYears = years.some((year) => year.style.display !== 'none');
            const objectiveMatch = currentObjective === '__all'
                || (groupCard.getAttribute('data-objective') || '') === currentObjective;
            groupCard.style.display = hasVisibleYears && objectiveMatch ? '' : 'none';
        });
    });

    // On initial load, respect URL hash (e.g. /faculty#student-data)
    const hash = window.location.hash ? window.location.hash.substring(1) : '';
    const queryParams = new URLSearchParams(window.location.search);
    const querySubject = (queryParams.get('subject') || '').trim() || null;
    const focusRequest = (queryParams.get('focusRequest') || '').trim();
    if (hash) {
        // Explicit subject from query should take priority when opening student-data
        if (hash === 'student-data' && querySubject) {
            const subjectLink = Array.from(links).find(
                (l) => l.dataset.target === 'student-data' && l.getAttribute('data-subject') === querySubject,
            );
            if (subjectLink) {
                activate('student-data', subjectLink);
                filterSubject(querySubject);
                return;
            }
            // If there is no dedicated link, still keep subject filter.
            const generalStudentLink = Array.from(links).find(
                (l) => l.dataset.target === 'student-data' && !l.getAttribute('data-subject'),
            );
            activate('student-data', generalStudentLink || null);
            currentSubject = querySubject;
            if (bulkSubjectInput) {
                bulkSubjectInput.value = currentSubject;
            }
            filterSubject(currentSubject);
            return;
        }

        // Try to find a matching sidebar link for this hash
        const match = Array.from(links).find((l) => l.getAttribute('href') === `#${hash}`);
        if (match) {
            const target = match.dataset.target || hash;
            const subject = match.getAttribute('data-subject');
            activate(target, match);
            if (target === 'student-data') {
                filterSubject(subject || null);
            }
            return;
        }
        // Fallback: activate panel by hash name directly if present
        const panelExists = Array.from(panels).some((p) => p.dataset.panel === hash);
        if (panelExists) {
            activate(hash);
            return;
        }
    }

    // Default view when no hash: pending approvals
    activate('pending');
    renderAnalyticsCharts();

    const focusRequestRow = () => {
        if (!focusRequest) return;

        const selector = `[data-request-id="${focusRequest}"]`;
        const row = document.querySelector(selector);
        if (!row) return;

        const mentorCard = row.closest('.mentor-subject-card');
        if (mentorCard) {
            mentorCard.open = true;
            // Open all nested details cards upward from the row
            let parent = row.closest('details');
            while (parent) {
                parent.open = true;
                parent = parent.closest('details');
            }
            const allChip = mentorSubjectChips.find((chip) => (chip.dataset.mentorSubject || '') === '__all');
            if (allChip) {
                mentorSubjectChips.forEach((c) => c.classList.toggle('active', c === allChip));
                filterMentorSubjectCards('__all');
            }
        }

        const objectiveCard = row.closest('.objective-group-card');
        if (objectiveCard) {
            objectiveCard.open = true;
            // Open all nested details cards upward from the row
            let parent = row.closest('details');
            while (parent) {
                parent.open = true;
                parent = parent.closest('details');
            }
            const allObjectiveChip = objectiveChips.find((chip) => (chip.dataset.objective || '') === '__all');
            if (allObjectiveChip) {
                objectiveChips.forEach((c) => c.classList.toggle('active', c === allObjectiveChip));
                filterObjectiveCards('__all');
            }
        }

        row.scrollIntoView({ behavior: 'smooth', block: 'center' });
        row.style.animation = 'pulse 0.8s ease';
        setTimeout(() => {
            row.style.animation = '';
        }, 900);
    };

    focusRequestRow();

    wrapTablesForScroll();

    // Helper function to show toast notification
    const showToast = (message, duration = 2000) => {
        const toast = document.createElement('div');
        toast.style.cssText = `
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #10b981;
            color: white;
            padding: 12px 20px;
            border-radius: 6px;
            font-size: 14px;
            z-index: 9999;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        `;
        toast.textContent = message;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), duration);
    };

    // AUTO-SAVE: Submit checkbox changes automatically via AJAX (Bulk assignments)
    const bulkForm = document.querySelector('.faculty-bulk-assignments');
    if (bulkForm) {
        const checkboxes = bulkForm.querySelectorAll('input[type="checkbox"]');
        const textInputs = bulkForm.querySelectorAll('input[type="text"][name*="facultyNote"]');
        
        const autoSubmitForm = async () => {
            // Collect form data manually
            const assignments = {};
            const subjectCodeField = bulkForm.querySelector('input[name="subjectCode"]');
            const subjectCode = subjectCodeField?.value || '';
            
            // Get all checkbox groups
            bulkForm.querySelectorAll('input[type="checkbox"], input[type="text"][name*="facultyNote"]').forEach((input) => {
                const nameAttr = input.getAttribute('name');
                if (!nameAttr) return;
                
                // Parse assignments[id][fieldName] format
                const match = nameAttr.match(/assignments\[([^\]]+)\]\[([^\]]+)\]/);
                if (!match) return;
                
                const [, id, fieldName] = match;
                if (!assignments[id]) {
                    assignments[id] = {};
                }
                
                if (input.type === 'checkbox') {
                    assignments[id][fieldName] = input.checked;
                } else if (input.type === 'text') {
                    assignments[id][fieldName] = input.value;
                }
            });
            
            try {
                const response = await fetch('/faculty/requests/bulk-assignments', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ assignments, subjectCode }),
                });
                
                if (response.ok) {
                    showToast('✓ Saved successfully');
                    refreshFacultyAnalytics();
                } else {
                    showToast('⚠ Save failed', 2000);
                }
            } catch (err) {
                console.error('Auto-save failed:', err);
                showToast('✗ Network error', 2000);
            }
        };
        
        // Debounce function to avoid too many requests
        let saveTimeout;
        const debouncedSave = () => {
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(autoSubmitForm, 500);
        };
        
        // Add listeners to all checkboxes
        checkboxes.forEach((checkbox) => {
            checkbox.addEventListener('change', debouncedSave);
        });
        
        // Also auto-save when remarks text changes
        textInputs.forEach((input) => {
            input.addEventListener('change', debouncedSave);
        });
    }

    // AUTO-SAVE: Submit checkbox changes for individual mentee forms
    const menteeForms = document.querySelectorAll('form[action*="/faculty/requests/"][action*="/assignments"]');
    menteeForms.forEach((form) => {
        const checkboxes = form.querySelectorAll('input[type="checkbox"]');
        
        if (checkboxes.length > 0) {
            let saveTimeout;
            
            const autoSubmitMenteeForm = async () => {
                const formData = new FormData(form);
                const action = form.getAttribute('action');
                
                try {
                    const response = await fetch(action, {
                        method: 'POST',
                        body: formData,
                    });
                    
                    if (response.ok) {
                        showToast('✓ Mentee data saved');
                        refreshFacultyAnalytics();
                    }
                } catch (err) {
                    console.error('Mentee auto-save failed:', err);
                }
            };
            
            const debouncedSave = () => {
                clearTimeout(saveTimeout);
                saveTimeout = setTimeout(autoSubmitMenteeForm, 500);
            };
            
            checkboxes.forEach((checkbox) => {
                checkbox.addEventListener('change', debouncedSave);
            });
        }
    });

    // AUTO-SAVE: Faculty approve/deny status toggles (no page reload)
    const facultyStatusToggles = Array.from(document.querySelectorAll('.faculty-request-status-toggle'));
    if (facultyStatusToggles.length) {
        const saveFacultyStatus = async (requestId, action) => {
            const response = await fetch(`/faculty/requests/${encodeURIComponent(requestId)}/autosave-status`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ action }),
            });

            if (!response.ok) {
                throw new Error(`Save failed: ${response.status}`);
            }
            return response.json();
        };

        facultyStatusToggles.forEach((toggle) => {
            toggle.addEventListener('change', async () => {
                const requestId = toggle.dataset.requestId || '';
                const row = toggle.closest('tr[data-request-id]');
                if (!requestId || !row) return;

                const approveToggle = row.querySelector('.faculty-request-status-toggle[data-action="approve"]');
                const denyToggle = row.querySelector('.faculty-request-status-toggle[data-action="deny"]');
                const statusText = row.querySelector('.faculty-request-status-text');
                if (!approveToggle || !denyToggle || !statusText) return;

                const prevApprove = approveToggle.checked;
                const prevDeny = denyToggle.checked;

                let action = 'pending';
                if (toggle.dataset.action === 'approve' && toggle.checked) {
                    denyToggle.checked = false;
                    action = 'approve';
                } else if (toggle.dataset.action === 'deny' && toggle.checked) {
                    approveToggle.checked = false;
                    action = 'deny';
                }

                if (!approveToggle.checked && !denyToggle.checked) {
                    action = 'pending';

    const facultyBackupSaveButtons = Array.from(document.querySelectorAll('.faculty-backup-save-btn'));
    if (facultyBackupSaveButtons.length) {
        const saveFacultyStatusRow = async (row) => {
            const requestId = row?.dataset?.requestId || '';
            if (!requestId) return false;

            const approveToggle = row.querySelector('.faculty-request-status-toggle[data-action="approve"]');
            const denyToggle = row.querySelector('.faculty-request-status-toggle[data-action="deny"]');
            const statusText = row.querySelector('.faculty-request-status-text');
            if (!approveToggle || !denyToggle || !statusText) return false;

            let action = 'pending';
            if (approveToggle.checked && !denyToggle.checked) {
                action = 'approve';
            } else if (denyToggle.checked && !approveToggle.checked) {
                action = 'deny';
            }

            const response = await fetch(`/faculty/requests/${encodeURIComponent(requestId)}/autosave-status`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ action }),
            });
            const result = await response.json().catch(() => ({}));
            if (!response.ok || !result.ok) {
                throw new Error(result.error || `Save failed: ${response.status}`);
            }

            if (result.status) {
                statusText.textContent = result.status;
            }
            return true;
        };

        const saveFacultyBackupScope = async (button) => {
            const saveScope = (button.dataset.saveScope || '').trim();
            button.disabled = true;

            try {
                if (saveScope === 'subject') {
                    const card = button.closest('.subject-group-card');
                    if (!card) throw new Error('Subject card not found');

                    const rows = Array.from(card.querySelectorAll('.faculty-subject-row'));
                    const subjectCode = card.dataset.subject || '';
                    const assignments = {};

                    rows.forEach((row) => {
                        const requestId = row.querySelector('input[type="checkbox"][name*="[assignment1]"]')?.name?.match(/assignments\[([^\]]+)\]/)?.[1]
                            || row.querySelector('input[type="checkbox"][name*="[assignment2]"]')?.name?.match(/assignments\[([^\]]+)\]/)?.[1]
                            || row.querySelector('input[type="text"][name*="[facultyNote]"]')?.name?.match(/assignments\[([^\]]+)\]/)?.[1]
                            || '';
                        if (!requestId) return;

                        const assignment1 = row.querySelector('input[type="checkbox"][name*="[assignment1]"]');
                        const assignment2 = row.querySelector('input[type="checkbox"][name*="[assignment2]"]');
                        const facultyNote = row.querySelector('input[type="text"][name*="[facultyNote]"]');

                        assignments[requestId] = {
                            assignment1: !!assignment1?.checked,
                            assignment2: !!assignment2?.checked,
                            facultyNote: facultyNote?.value || '',
                        };
                    });

                    const response = await fetch('/faculty/requests/bulk-assignments', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                            'X-Requested-With': 'fetch',
                        },
                        body: JSON.stringify({ assignments, subjectCode }),
                    });
                    const result = await response.json().catch(() => ({}));
                    if (!response.ok || !result.ok) {
                        throw new Error(result.error || `Backup save failed: ${response.status}`);
                    }

                    showToast(`✓ Backup saved ${result.updatedCount || rows.length} row(s)`);
                    await refreshFacultyAnalytics();
                    return;
                }

                let rows = [];
                if (saveScope === 'pending') {
                    rows = Array.from(document.querySelectorAll('[data-backup-scope="pending"] tr[data-request-id]'));
                } else if (saveScope === 'mentor') {
                    const card = button.closest('.mentor-subject-card');
                    rows = card ? Array.from(card.querySelectorAll('.faculty-mentor-row')) : [];
                } else if (saveScope === 'objective') {
                    const card = button.closest('.objective-group-card');
                    rows = card ? Array.from(card.querySelectorAll('.faculty-objective-row')) : [];
                } else if (saveScope === 'mentee') {
                    const table = document.querySelector('#mentee-table');
                    rows = table ? Array.from(table.querySelectorAll('tr[data-request-id]')) : [];
                }

                let savedCount = 0;
                for (const row of rows) {
                    if (await saveFacultyStatusRow(row)) savedCount += 1;
                }

                showToast(`✓ Backup saved ${savedCount} row(s)`);
                await refreshFacultyAnalytics();
            } catch (err) {
                console.error('Faculty backup save failed:', err);
                showToast('✗ Backup save failed', 2000);
            } finally {
                button.disabled = false;
            }
        };

        facultyBackupSaveButtons.forEach((button) => {
            button.addEventListener('click', (event) => {
                event.preventDefault();
                event.stopPropagation();
                saveFacultyBackupScope(button);
            });
        });
    }
                }

                approveToggle.disabled = true;
                denyToggle.disabled = true;

                try {
                    const result = await saveFacultyStatus(requestId, action);
                    if (result && result.ok && result.status) {
                        statusText.textContent = result.status;
                        showToast('✓ Status saved');
                        refreshFacultyAnalytics();
                    } else {
                        throw new Error('Invalid response');
                    }
                } catch (err) {
                    console.error('Faculty status autosave failed:', err);
                    approveToggle.checked = prevApprove;
                    denyToggle.checked = prevDeny;
                    showToast('✗ Save failed', 2000);
                } finally {
                    approveToggle.disabled = false;
                    denyToggle.disabled = false;
                }
            });
        });
    }

    const updateSubjectBulkRows = (subjectCode, bulkAction) => {
        if (!subjectCode) return;
        const card = Array.from(document.querySelectorAll('.subject-group-card'))
            .find((groupCard) => (groupCard.getAttribute('data-subject') || '') === subjectCode);
        if (!card) return;

        card.querySelectorAll('.faculty-subject-row').forEach((row) => {
            const assignment1 = row.querySelector('input[type="checkbox"][name*="[assignment1]"]');
            const assignment2 = row.querySelector('input[type="checkbox"][name*="[assignment2]"]');
            const facultyNote = row.querySelector('input[type="text"][name*="[facultyNote]"]');

            if (assignment1) assignment1.checked = bulkAction !== 'revoke';
            if (assignment2) assignment2.checked = bulkAction !== 'revoke';
            if (facultyNote) facultyNote.value = bulkAction === 'revoke' ? '' : (facultyNote.value || 'Approved by faculty (bulk)');
        });
    };

    const updateMentorBulkRows = (bulkAction) => {
        document.querySelectorAll('.mentor-subject-card .faculty-mentor-row').forEach((row) => {
            const approveToggle = row.querySelector('.faculty-request-status-toggle[data-action="approve"]');
            const denyToggle = row.querySelector('.faculty-request-status-toggle[data-action="deny"]');
            const statusText = row.querySelector('.faculty-request-status-text');
            if (approveToggle) approveToggle.checked = bulkAction !== 'revoke';
            if (denyToggle) denyToggle.checked = false;
            if (statusText) statusText.textContent = bulkAction === 'revoke' ? 'Pending Faculty' : 'Approved';
        });
    };

    const updateObjectiveBulkRows = (objectiveCode, bulkAction) => {
        const objectiveKey = (objectiveCode || '').replace(/^OBJECTIVE::/, '');
        const cards = objectiveKey
            ? Array.from(document.querySelectorAll('.objective-group-card')).filter((card) => (card.getAttribute('data-objective') || '') === objectiveKey)
            : Array.from(document.querySelectorAll('.objective-group-card'));

        cards.forEach((card) => {
            card.querySelectorAll('.faculty-objective-row').forEach((row) => {
                const approveToggle = row.querySelector('.faculty-request-status-toggle[data-action="approve"]');
                const denyToggle = row.querySelector('.faculty-request-status-toggle[data-action="deny"]');
                const statusText = row.querySelector('.faculty-request-status-text');
                if (approveToggle) approveToggle.checked = bulkAction !== 'revoke';
                if (denyToggle) denyToggle.checked = false;
                if (statusText) statusText.textContent = bulkAction === 'revoke' ? 'Pending Faculty' : 'Approved';
            });
        });
    };

    const bulkApproveForms = Array.from(document.querySelectorAll('form[action="/faculty/requests/approve-all"]'));
    bulkApproveForms.forEach((form) => {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(form);
            const scope = (formData.get('scope') || '').toString().trim();
            const bulkAction = (formData.get('bulkAction') || 'approve').toString().trim();
            const subjectCode = (formData.get('subjectCode') || '').toString().trim();
            const objectiveCode = (formData.get('objectiveCode') || '').toString().trim();

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'Accept': 'application/json',
                        'X-Requested-With': 'fetch',
                    },
                    body: new URLSearchParams(formData).toString(),
                });

                const result = await response.json().catch(() => ({}));
                if (!response.ok || !result.ok) {
                    throw new Error(result.error || `Bulk save failed: ${response.status}`);
                }

                if (scope === 'subject') {
                    updateSubjectBulkRows(subjectCode, bulkAction);
                } else if (scope === 'mentor') {
                    updateMentorBulkRows(bulkAction);
                } else if (scope === 'objective') {
                    updateObjectiveBulkRows(objectiveCode, bulkAction);
                }

                await refreshFacultyAnalytics();
                showToast(`✓ Updated ${result.updatedCount || 0} request(s)`);
            } catch (err) {
                console.error('Bulk faculty action failed:', err);
                showToast('✗ Bulk update failed', 2000);
            }
        });
    });
})();
</script>

<%- include('partials/footer') %>
